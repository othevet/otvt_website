---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import PageAnimations from '../components/PageAnimations.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { getImage } from 'astro:assets';
import meImage from '../assets/me.png';
import { routes, getPageKeyFromPath, type Locale } from '../i18n/routes';

export interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  pageKey?: keyof (typeof routes)['fr'];
}

const { title, description, noindex, pageKey } = Astro.props;
const locale = (Astro.currentLocale ?? 'fr') as Locale;
const resolvedPageKey =
  pageKey ??
  getPageKeyFromPath(Astro.url.pathname.replace(/\/$/, '') || '/', locale);

const defaultTitles = {
  fr: 'OTVT — Studio Web | Développeur Web Indépendant',
  en: 'OTVT — Web Studio | Independent Web Developer',
};
const defaultDescriptions = {
  fr: 'Développeur web indépendant à Origny le Sec (Aube). WordPress, Next.js, Astro, applications sur mesure. Je donne vie à vos idées.',
  en: 'Independent web developer based in France, working with clients worldwide. WordPress, Next.js, Astro, custom applications. I bring your ideas to life.',
};

const siteTitle = title ? `${title} — OTVT` : defaultTitles[locale];
const siteDescription = description ?? defaultDescriptions[locale];
const canonical = Astro.url.origin + Astro.url.pathname;

const alternates = resolvedPageKey
  ? (Object.keys(routes) as Locale[]).map((loc) => ({
      lang: loc,
      href: Astro.url.origin + routes[loc][resolvedPageKey],
    }))
  : [];

const ogImage = await getImage({
  src: meImage,
  width: 1200,
  height: 1200,
  format: 'jpg',
  fit: 'cover',
  position: 'top',
});
const ogImageUrl = new URL(ogImage.src, Astro.url.origin).toString();

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Olivier Thévet - OTVT',
  image: ogImageUrl,
  url: Astro.url.origin,
  email: 'contact@otvt.fr',
  telephone: '+33635229246',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Origny-le-Sec',
    addressRegion: 'Aube',
    addressCountry: 'FR',
  },
  founder: {
    '@type': 'Person',
    name: 'Olivier Thévet',
  },
  description: siteDescription,
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <script is:inline>
      (function () {
        function applyStoredTheme() {
          const stored = localStorage.getItem('theme');
          if (stored === 'dark' || stored === 'light') {
            document.documentElement.dataset.theme = stored;
          } else {
            delete document.documentElement.dataset.theme;
          }
        }
        applyStoredTheme();
        document.addEventListener('astro:after-swap', applyStoredTheme);
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="theme-color"
      content="#f0efec"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#16211b"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta
      name="robots"
      content={noindex ? 'noindex, nofollow' : 'index, follow'}
    />
    {
      alternates.map(({ lang, href }) => (
        <link rel="alternate" hreflang={lang} href={href} />
      ))
    }
    {
      alternates.length > 0 && (
        <link rel="alternate" hreflang="x-default" href={Astro.url.origin + routes.fr[resolvedPageKey!]} />
      )
    }
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Dancing+Script:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
  </head>
  <body
    class="bg-bg text-ink font-['Space_Grotesk',sans-serif] antialiased overflow-x-hidden min-h-screen"
  >
    <Header />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />
    <ScrollIndicator />
    <PageAnimations />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
