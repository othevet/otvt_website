---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title?: string;
  description?: string;
  theme?: 'dark' | 'light';
}

const { title, description, theme = 'dark' } = Astro.props;
---

<!doctype html>
<html lang="fr" class={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <title>{title ? `${title} — OTVT` : 'OTVT — Développement Web sur Mesure'}</title>
    <meta name="description" content={description ?? 'Agence de développement web : WordPress, sites sur mesure, Next.js, Astro.'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-deep-900 text-gray-100 font-['Inter',sans-serif] antialiased">
    <Header />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />
    <ScrollReveal />
  </body>
</html>
