<style is:global>
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }
  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  [data-intro] {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  [data-intro='down'] {
    transform: translateY(-14px);
  }
  [data-intro].is-intro-in {
    opacity: 1;
    transform: translateY(0);
  }

  [data-typewriter].is-typing::after {
    content: '';
    display: inline-block;
    width: 0.5em;
    height: 1em;
    margin-left: 2px;
    background: currentColor;
    vertical-align: text-bottom;
    animation: typewriter-blink 0.9s step-end infinite;
  }
  @keyframes typewriter-blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
    [data-intro] {
      opacity: 1;
      transform: none;
      transition: none;
    }
    [data-typewriter].is-typing::after {
      animation: none;
    }
  }
</style>

<script>
  function initScrollReveal() {
    const elements = document.querySelectorAll<HTMLElement>(
      '[data-reveal]:not(.is-revealed)',
    );
    if (elements.length === 0) return;

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
      elements.forEach((el) => el.classList.add('is-revealed'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' },
    );

    elements.forEach((el, index) => {
      el.style.transitionDelay = `${Math.min(index, 3) * 80}ms`;
      observer.observe(el);
    });
  }

  function initTypewriter() {
    const elements = document.querySelectorAll<HTMLElement>(
      '[data-typewriter]',
    );
    elements.forEach((el) => {
      if (el.dataset.initialized) return;
      el.dataset.initialized = 'true';

      const text = el.textContent ?? '';
      if (!text || matchMedia('(prefers-reduced-motion: reduce)').matches)
        return;

      el.textContent = '';
      el.classList.add('is-typing');
      let i = 0;
      const step = () => {
        i++;
        el.textContent = text.slice(0, i);
        if (i < text.length) {
          setTimeout(step, 28);
        } else {
          el.classList.remove('is-typing');
        }
      };
      setTimeout(step, 250);
    });
  }

  function initIntro() {
    const elements = document.querySelectorAll<HTMLElement>(
      '[data-intro]:not(.is-intro-in)',
    );
    if (elements.length === 0) return;

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
      elements.forEach((el) => el.classList.add('is-intro-in'));
      return;
    }

    elements.forEach((el) => {
      el.style.transitionDelay = `${el.dataset.introDelay ?? '0'}ms`;
    });

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        elements.forEach((el) => el.classList.add('is-intro-in'));
      });
    });
  }

  function initPageAnimations() {
    initIntro();
    initScrollReveal();
    initTypewriter();
  }

  initPageAnimations();
  document.addEventListener('astro:page-load', initPageAnimations);
</script>
