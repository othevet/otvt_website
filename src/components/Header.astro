---
const pages = [
  { path: '/', label: 'Accueil' },
  { path: '/app', label: 'Réalisations' },
  { path: '/services', label: 'Services' },
  { path: '/a-propos', label: 'À propos' },
  { path: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header
  class="relative z-50 border-b border-vert/10 bg-[#F0EFEC]/80 backdrop-blur-sm"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex items-center justify-between pt-4 pb-4 sm:pt-5 sm:pb-5">
      <a href="/" class="flex flex-col leading-tight">
        <span class="text-sm font-semibold text-[#2d2a24]">Olivier Thévet</span>
        <span class="text-xs text-[#2d2a24]/70">otvt</span>
      </a>

      <div
        class="hidden sm:flex items-center gap-1 bg-white rounded-full px-2 py-1.5 shadow-sm border border-black/5"
      >
        {
          pages.map(({ path, label }) => (
            <a
              href={path}
              class="px-4 py-1.5 text-sm font-medium rounded-full transition-all duration-200"
              class:list={
                currentPath === path
                  ? 'bg-vert text-white'
                  : 'text-[#2d2a24]/60 hover:text-[#2d2a24] hover:bg-black/5'
              }
            >
              {label}
            </a>
          ))
        }
      </div>

      <button
        id="menu-toggle"
        class="sm:hidden p-2 text-[#2d2a24]/60 hover:text-[#2d2a24] transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Ouvrir le menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="3" y1="6" x2="21" y2="6"></line><line
            x1="3"
            y1="12"
            x2="21"
            y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
        >
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden sm:hidden bg-white mt-2 mx-6 rounded-2xl shadow-sm border border-black/5 overflow-hidden"
  >
    <div class="p-4 space-y-1">
      {
        pages.map(({ path, label }) => (
          <a
            href={path}
            class="block px-4 py-2.5 text-sm rounded-xl transition-colors"
            class:list={
              currentPath === path
                ? 'bg-vert text-white'
                : 'text-[#2d2a24]/60 hover:bg-black/5'
            }
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  function initMenuToggle() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      const isHidden = menu?.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isHidden));
      toggle.setAttribute(
        'aria-label',
        isHidden ? 'Ouvrir le menu' : 'Fermer le menu',
      );
    });
  }

  initMenuToggle();
  document.addEventListener('astro:page-load', initMenuToggle);
</script>
