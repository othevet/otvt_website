---
const pages = [
  { path: '/', label: 'Accueil' },
  { path: '/services', label: 'Services' },
  { path: '/blog', label: 'Journal' },
  { path: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 mix-blend-difference">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
    <a href="/" class="text-sm font-semibold tracking-wide text-white/80 hover:text-white transition-colors">
      OTVT
    </a>
    <ul class="hidden sm:flex items-center gap-8">
      {pages.map(({ path, label }) => (
        <li>
          <a href={path} class="text-sm text-white/50 hover:text-white/80 transition-colors">
            {label}
          </a>
        </li>
      ))}
    </ul>
    <button id="menu-toggle" class="sm:hidden p-2 text-white/60 hover:text-white transition-colors" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </nav>
  <div id="mobile-menu" class="hidden sm:hidden bg-white/95 backdrop-blur-xl border-t border-black/5">
    <div class="px-6 py-4 space-y-3">
      {pages.map(({ path, label }) => (
        <a href={path} class="block text-sm text-black/60 hover:text-black py-1">{label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
