---
const pages = [
  { path: '/', label: 'Accueil' },
  { path: '/services', label: 'Services' },
  { path: '/blog', label: 'Blog' },
  { path: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="relative z-50">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex items-center justify-between pt-6">
      <a href="/" class="font-['Dancing_Script',cursive] text-3xl sm:text-4xl font-bold text-vert hover:text-vert/80 transition-colors">
        OTVT
      </a>

      <div class="hidden sm:flex items-center gap-1 bg-white rounded-full px-2 py-1.5 shadow-sm border border-black/5">
        {pages.map(({ path, label }) => (
          <a
            href={path}
            class="px-4 py-1.5 text-sm font-medium rounded-full transition-all duration-200"
            class:list={currentPath === path
              ? 'bg-vert text-white'
              : 'text-[#2d2a24]/60 hover:text-[#2d2a24] hover:bg-black/5'
            }
          >
            {label}
          </a>
        ))}
      </div>

      <div class="hidden sm:flex flex-col items-end leading-tight">
        <span class="text-sm font-semibold text-[#2d2a24]">Olivier Thévet</span>
        <span class="text-xs text-[#2d2a24]/40">otvt</span>
      </div>

      <button id="menu-toggle" class="sm:hidden p-2 text-[#2d2a24]/60 hover:text-[#2d2a24] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden sm:hidden bg-white mt-2 mx-6 rounded-2xl shadow-sm border border-black/5 overflow-hidden">
    <div class="p-4 space-y-1">
      {pages.map(({ path, label }) => (
        <a href={path} class="block px-4 py-2.5 text-sm rounded-xl transition-colors" class:list={currentPath === path ? 'bg-vert text-white' : 'text-[#2d2a24]/60 hover:bg-black/5'}>{label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
