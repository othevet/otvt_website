---
import { routes, getPageKeyFromPath, type Locale } from '../i18n/routes';
import { ui } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'fr') as Locale;
const otherLocale: Locale = locale === 'fr' ? 'en' : 'fr';
const t = ui[locale];
const accountLabel = t.account.accountEyebrow;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const pageKey = getPageKeyFromPath(currentPath, locale) ?? 'home';
const switchHref = routes[otherLocale][pageKey];

const pages = [
  { path: routes[locale].home, label: t.nav.home },
  { path: routes[locale].work, label: t.nav.work },
  { path: routes[locale].services, label: t.nav.services },
  { path: routes[locale].about, label: t.nav.about },
  { path: routes[locale].contact, label: t.nav.contact },
];
---

<header
  class="relative z-50 border-b border-vert/10 bg-bg/80 backdrop-blur-sm"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex items-center justify-between pt-4 pb-4 sm:pt-5 sm:pb-5">
      <a href={routes[locale].home} class="flex flex-col leading-tight">
        <span class="text-sm font-semibold text-ink">Olivier Thévet</span>
        <span class="text-xs text-ink/70">otvt</span>
      </a>

      <div class="hidden sm:flex items-center gap-3">
        <div
          class="flex items-center gap-1 bg-surface rounded-full px-2 py-1.5 shadow-sm border border-hairline"
        >
          {
            pages.map(({ path, label }) => (
              <a
                href={path}
                class="px-4 py-1.5 text-sm font-medium rounded-full transition-all duration-200"
                class:list={
                  currentPath === path
                    ? 'bg-vert text-white'
                    : 'text-ink/70 hover:text-ink hover:bg-hairline'
                }
              >
                {label}
              </a>
            ))
          }
        </div>
        <button
          type="button"
          data-theme-toggle
          aria-label={t.themeToggleLabel}
          title={t.themeToggleLabel}
          class="theme-toggle p-2 rounded-full border border-vert/20 text-ink/70 hover:text-vert hover:border-vert/40 transition-colors"
        >
          <svg
            class="icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"
            ></path></svg
          >
          <svg
            class="icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="4"></circle><path
              d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
            ></path></svg
          >
        </button>
        <a
          href={routes[locale].login}
          aria-label={accountLabel}
          title={accountLabel}
          class="p-2 rounded-full border border-vert/20 text-ink/70 hover:text-vert hover:border-vert/40 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle
              cx="12"
              cy="7"
              r="4"></circle></svg
          >
        </a>
        <a
          href={switchHref}
          aria-label={t.langSwitchLabel}
          class="px-3 py-1.5 text-xs font-semibold rounded-full border border-vert/20 text-ink/70 hover:text-vert hover:border-vert/40 transition-colors"
        >
          {t.langSwitch}
        </a>
      </div>

      <div class="flex items-center gap-1 sm:hidden">
        <button
          type="button"
          data-theme-toggle
          aria-label={t.themeToggleLabel}
          class="theme-toggle p-2 rounded-full border border-vert/20 text-ink/70"
        >
          <svg
            class="icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"
            ></path></svg
          >
          <svg
            class="icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="4"></circle><path
              d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
            ></path></svg
          >
        </button>
        <a
          href={routes[locale].login}
          aria-label={accountLabel}
          class="p-2 rounded-full border border-vert/20 text-ink/70"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle
              cx="12"
              cy="7"
              r="4"></circle></svg
          >
        </a>
        <a
          href={switchHref}
          aria-label={t.langSwitchLabel}
          class="px-2.5 py-1 text-xs font-semibold rounded-full border border-vert/20 text-ink/70"
        >
          {t.langSwitch}
        </a>
        <button
          id="menu-toggle"
          class="p-2 text-ink/60 hover:text-ink transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label={t.menuOpen}
          data-label-open={t.menuOpen}
          data-label-close={t.menuClose}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="3" y1="6" x2="21" y2="6"></line><line
              x1="3"
              y1="12"
              x2="21"
              y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
          >
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden sm:hidden bg-surface mt-2 mx-6 rounded-2xl shadow-sm border border-hairline overflow-hidden"
  >
    <div class="p-4 space-y-1">
      {
        pages.map(({ path, label }) => (
          <a
            href={path}
            class="block px-4 py-2.5 text-sm rounded-xl transition-colors"
            class:list={
              currentPath === path
                ? 'bg-vert text-white'
                : 'text-ink/70 hover:bg-hairline'
            }
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<style is:global>
  .theme-toggle .icon-sun {
    display: none;
  }
  .theme-toggle .icon-moon {
    display: block;
  }

  :root[data-theme='dark'] .theme-toggle .icon-sun {
    display: block;
  }
  :root[data-theme='dark'] .theme-toggle .icon-moon {
    display: none;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .theme-toggle .icon-sun {
      display: block;
    }
    :root:not([data-theme='light']) .theme-toggle .icon-moon {
      display: none;
    }
  }
</style>

<script>
  function initThemeToggle() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(
      '[data-theme-toggle]',
    );
    buttons.forEach((button) => {
      if (button.dataset.initialized) return;
      button.dataset.initialized = 'true';
      button.addEventListener('click', () => {
        const root = document.documentElement;
        const current =
          root.dataset.theme ??
          (matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light');
        const next = current === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    });
  }

  function initMenuToggle() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      const isHidden = menu?.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isHidden));
      toggle.setAttribute(
        'aria-label',
        isHidden
          ? (toggle.dataset.labelOpen ?? '')
          : (toggle.dataset.labelClose ?? ''),
      );
    });
  }

  initThemeToggle();
  initMenuToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
  document.addEventListener('astro:page-load', initMenuToggle);
</script>
