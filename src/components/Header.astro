---
const pages = [
  { path: '/', label: 'accueil' },
  { path: '/services', label: 'services' },
  { path: '/blog', label: 'blog' },
  { path: '/contact', label: 'contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-deep-900/80 backdrop-blur-xl font-['JetBrains_Mono',monospace]">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-1.5 text-sm font-semibold group">
      <span class="text-indigo-400">❯</span>
      <span class="text-white">otvt</span>
      <span class="text-gray-600 group-hover:text-gray-400 transition-colors">/dev</span>
    </a>

    <ul class="hidden sm:flex items-center gap-0.5">
      {pages.map(({ path, label }) => (
        <li>
          <a
            href={path}
            class="px-3 py-1.5 text-xs rounded-md transition-all duration-200"
            class:list={currentPath === path
              ? 'text-indigo-300 bg-indigo-500/10'
              : 'text-gray-500 hover:text-gray-300 hover:bg-white/5'
            }
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="/contact"
        class="hidden sm:inline-flex items-center gap-1.5 rounded-lg bg-gradient-to-r from-indigo-600 to-purple-600 px-4 py-1.5 text-xs font-semibold text-white shadow-lg shadow-indigo-500/20 transition-all duration-200 hover:shadow-indigo-500/40"
      >
        ./contact.sh
      </a>
      <button id="menu-toggle" class="sm:hidden p-1.5 text-gray-500 hover:text-white transition-colors" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-white/5 bg-deep-900 px-4 pb-4 sm:hidden">
    <ul class="flex flex-col gap-0.5 pt-2">
      {pages.map(({ path, label }) => (
        <li>
          <a
            href={path}
            class="block rounded-md px-3 py-2 text-xs transition-colors"
            class:list={currentPath === path ? 'text-indigo-300 bg-indigo-500/10' : 'text-gray-500 hover:text-gray-300 hover:bg-white/5'}
          >
            <span class="text-indigo-400">❯</span> {label}
          </a>
        </li>
      ))}
      <li class="mt-2">
        <a href="/contact" class="block rounded-lg bg-gradient-to-r from-indigo-600 to-purple-600 px-3 py-2 text-xs font-semibold text-white text-center">
          ./contact.sh
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
