<section class="px-6 sm:px-12 lg:px-16 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="grid sm:grid-cols-3 gap-12 sm:gap-16">
      <div class="sm:col-span-1">
        <p class="reveal text-xs font-medium tracking-[0.15em] text-black/30 uppercase">Savoir-faire</p>
        <h2 class="reveal reveal-delay-1 mt-4 text-3xl sm:text-4xl font-['DM_Serif_Display',serif] text-[#1d1d1f]">Ce que je fais</h2>
      </div>
      <div class="sm:col-span-2 space-y-10">
        {[
          { title: 'WordPress', desc: 'Thèmes sur mesure, WooCommerce, plugins. Pas de template pré-fait — du sur-mesure pensé pour vos objectifs.' },
          { title: 'Sites sur mesure', desc: 'Next.js, Astro, React. Des sites ultra-rapides, modernes et évolutifs, déployés en continu.' },
          { title: 'Maintenance & SEO', desc: 'Audit, sécurité, performance. Je garde votre site en bonne santé et à la page.' },
        ].map((item, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.1}s`}>
            <h3 class="text-lg font-semibold text-[#1d1d1f]">{item.title}</h3>
            <p class="mt-2 text-sm text-black/40 leading-relaxed max-w-lg">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="bg-[#f8f8f8] px-6 sm:px-12 lg:px-16 py-24 sm:py-32">
