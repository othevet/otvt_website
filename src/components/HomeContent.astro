---
import { Image } from 'astro:assets';
import meImage from '../assets/me.png';
---

<section class="relative min-h-screen flex items-center py-20 sm:py-24">
  <div class="mx-auto w-full max-w-7xl px-6">
    <div
      class="border border-vert/20 rounded-2xl overflow-hidden bg-white shadow-sm"
    >
      <!-- Terminal title bar -->
      <div
        class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-[#F8F8F6]"
      >
        <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
        <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
        <span class="ml-3 text-xs text-[#2d2a24]/30 font-medium"
          >olivier@otvt:~/studio</span
        >
      </div>
      <!-- Content -->
      <div class="px-6 sm:px-12 py-8 sm:py-14">
        <!-- Prompt -->
        <p class="text-xs text-vert/70 font-mono mb-8 sm:mb-10 leading-relaxed">
          <span class="text-vert font-semibold">olivier@otvt</span>:<span
            class="text-jaune">~</span
          ><span class="text-[#2d2a24]/25">$ </span><span
            class="text-[#2d2a24]/40">cat hero.txt</span
          >
        </p>
        <!-- Layout -->
        <div class="grid sm:grid-cols-2 gap-12 sm:gap-16 items-center">
          <div class="flex flex-col">
            <p
              class="text-xs font-medium tracking-[0.15em] text-vert/80 uppercase mb-6"
            >
              Studio de développement
            </p>
            <h1
              class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-[-0.04em] leading-[0.9] text-[#2d2a24]"
            >
              <div>DONNER VIE</div>
              <div class="text-vert">À VOS IDÉES</div>
            </h1>
            <p class="mt-6 text-base sm:text-lg text-[#2d2a24]/50 max-w-md">
              WordPress, sites sur mesure, applications. Chaque projet est
              pensé, conçu et livré avec soin.
            </p>
            <div class="mt-8 flex items-center gap-4">
              <a
                href="/contact"
                class="inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm hover:shadow-md"
              >
                Démarrer un projet
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                  ></path></svg
                >
              </a>
              <a
                href="/services"
                class="text-sm text-[#2d2a24]/40 hover:text-[#2d2a24] transition-colors"
              >
                En savoir plus
              </a>
            </div>
          </div>
          <div class="flex justify-center sm:justify-end">
            <div class="relative">
              <div class="absolute -inset-6 bg-jaune/20 rounded-full blur-3xl">
              </div>
              <div class="relative w-64 h-64 sm:w-80 sm:h-80">
                <Image
                  src={meImage}
                  alt="Olivier"
                  width={320}
                  height={320}
                  fit="cover"
                  position="top"
                  class="w-full h-full rounded-full object-cover object-top shadow-xl"
                  loading="eager"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
