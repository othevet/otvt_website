---
const lines = [
  { text: '╭──────────────────────────────────────────╮', delay: 100 },
  { text: '│  ⚡ OTVT Dev — Web Engineering Studio    │', delay: 80 },
  { text: '╰──────────────────────────────────────────╯', delay: 100 },
  { text: '', delay: 100 },
  { text: '$ npx otvt --help', delay: 600 },
  { text: '', delay: 200 },
  { text: '  Usage: otvt <project> [options]', delay: 40 },
  { text: '', delay: 40 },
  { text: '  Commands:', delay: 40 },
  { text: '    $wordpress     WordPress sur mesure     [--theme --woo]', delay: 30 },
  { text: '    $custom        Sites sur mesure          [--next --astro]', delay: 30 },
  { text: '    $maintain      Maintenance & SEO         [--audit --perf]', delay: 30 },
  { text: '    $consult       Conseil & Architecture    [--stack --code]', delay: 30 },
  { text: '', delay: 40 },
  { text: '  Options:', delay: 40 },
  { text: '    --free-quote   Devis gratuit sous 48h', delay: 30 },
  { text: '    --fast          Réponse sous 24h', delay: 30 },
  { text: '    --human         Humain, pas de robot 🤘', delay: 30 },
  { text: '', delay: 100 },
  { text: '$ █', delay: 400 },
];
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-deep-900">
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,.4) 1px, transparent 0); background-size: 30px 30px;" />

  <div class="mx-auto w-full max-w-3xl px-4">
    <div class="rounded-2xl border border-white/10 bg-deep-800/80 shadow-2xl shadow-indigo-500/5 backdrop-blur-sm overflow-hidden">
      <div class="flex items-center gap-2 border-b border-white/5 px-4 py-3">
        <span class="h-3 w-3 rounded-full bg-red-500/80" />
        <span class="h-3 w-3 rounded-full bg-yellow-500/80" />
        <span class="h-3 w-3 rounded-full bg-green-500/80" />
        <span class="ml-3 text-xs text-gray-600 font-['JetBrains_Mono',monospace]">otvt@dev — bash</span>
      </div>

      <div id="terminal-output" class="p-5 sm:p-8 font-['JetBrains_Mono',monospace] text-sm leading-relaxed">
        {lines.map((line, i) => (
          <div id={`line-${i}`} class="hidden" data-delay={line.delay}>
            {line.text.startsWith('$') ? (
              <span>
                <span class="text-indigo-400">❯</span>{' '}
                <span class="text-gray-300">{line.text.slice(1)}</span>
              </span>
            ) : line.text.startsWith('  $') ? (
              <span class="text-gray-400">
                {'  '}<span class="text-indigo-400">❯</span>{' '}
                <span class="text-indigo-300 font-semibold">{line.text.match(/\$(\w+)/)?.[1]}</span>
                {line.text.replace(/\s+\$\w+/, '')}
              </span>
            ) : (
              <span class="text-gray-500">{line.text}</span>
            )}
            <wbr />
          </div>
        ))}
      </div>
    </div>

    <p class="mt-6 text-center text-sm text-gray-600 font-['JetBrains_Mono',monospace]">
      <span class="text-indigo-400">❯</span> tapez <span class="text-indigo-300">./contact.sh</span> pour démarrer un projet
    </p>
  </div>
</section>

<script>
  (() => {
    const lines = document.querySelectorAll('[id^="line-"]');
    let current = 0;

    function showNext() {
      if (current >= lines.length) return;
      const line = lines[current];
      line.classList.remove('hidden');
      const delay = parseInt(line.dataset.delay || '50', 10);
      current++;
      setTimeout(showNext, delay);
    }

    setTimeout(showNext, 500);
  })();
</script>

<style>
  [id^="line-"] { white-space: pre-wrap; }
</style>
