---
import { routes, type Locale } from '../i18n/routes';
import { ui } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'fr') as Locale;
const t = ui[locale];

const pages = [
  { path: routes[locale].home, label: t.nav.home },
  { path: routes[locale].work, label: t.nav.work },
  { path: routes[locale].services, label: t.nav.services },
  { path: routes[locale].about, label: t.nav.about },
  { path: routes[locale].contact, label: t.nav.contact },
];
---

<footer class="border-t border-hairline bg-surface/40">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="flex flex-col sm:flex-row items-start justify-between gap-8">
      <div class="flex flex-col leading-tight">
        <span class="text-sm font-semibold text-ink">Olivier Thévet</span>
        <span class="text-xs text-ink/70">otvt</span>
      </div>
      <div class="flex flex-wrap gap-10 text-sm">
        <div>
          <ul class="space-y-2">
            {
              pages.map(({ path, label }) => (
                <li>
                  <a
                    href={path}
                    class="text-ink/70 hover:text-vert transition-colors"
                  >
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <ul class="space-y-2 text-ink/70">
            <li>
              <a
                href="mailto:contact@otvt.fr"
                class="hover:text-vert transition-colors">contact@otvt.fr</a
              >
            </li>
            <li>{t.footer.location}</li>
          </ul>
        </div>
      </div>
    </div>
    <div
      class="mt-10 pt-6 border-t border-hairline text-xs text-ink/70 flex items-center justify-between"
    >
      <p>&copy; {new Date().getFullYear()} OTVT</p>
      <a href={routes[locale].legal} class="hover:text-vert transition-colors"
        >{t.footer.legal}</a
      >
    </div>
  </div>
</footer>
