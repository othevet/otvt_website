---
export interface Props {
  command: string;
  description: string;
  tags: string[];
  color?: string;
  delay?: number;
}

const { command, description, tags, color = 'indigo', delay = 0 } = Astro.props;
const colors: Record<string, { accent: string; tag: string; border: string }> = {
  indigo: { accent: 'text-indigo-400', tag: 'bg-indigo-500/10 text-indigo-300', border: 'border-indigo-500/20' },
  purple: { accent: 'text-purple-400', tag: 'bg-purple-500/10 text-purple-300', border: 'border-purple-500/20' },
  cyan: { accent: 'text-cyan-400', tag: 'bg-cyan-500/10 text-cyan-300', border: 'border-cyan-500/20' },
  amber: { accent: 'text-amber-400', tag: 'bg-amber-500/10 text-amber-300', border: 'border-amber-500/20' },
};
const c = colors[color] ?? colors.indigo;
---

<div class="reveal group rounded-xl border border-white/5 bg-deep-800/40 p-5 sm:p-6 transition-all duration-300 hover:bg-deep-800/80" class:list={[c.border]}>
  <div class="flex items-start gap-3">
    <span class={`mt-0.5 shrink-0 ${c.accent} font-['JetBrains_Mono',monospace] text-xs`}>❯</span>
    <div class="min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <span class={`font-['JetBrains_Mono',monospace] text-sm font-semibold ${c.accent} group-hover:text-white transition-colors`}>
          {command}
        </span>
        <span class="text-xs text-gray-600"># {description}</span>
      </div>

      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map(tag => (
            <span class={`rounded-md px-2 py-0.5 text-xs font-['JetBrains_Mono',monospace] ${c.tag}`}>
              --{tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</div>
