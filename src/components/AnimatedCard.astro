---
export interface Props {
  icon: string;
  title: string;
  description: string;
  color: string;
  delay: number;
}

const { icon, title, description, color, delay } = Astro.props;
const colors: Record<string, { bg: string; text: string; border: string }> = {
  indigo: { bg: 'bg-indigo-500/10', text: 'text-indigo-400', border: 'border-indigo-500/10 hover:border-indigo-500/30' },
  purple: { bg: 'bg-purple-500/10', text: 'text-purple-400', border: 'border-purple-500/10 hover:border-purple-500/30' },
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-400', border: 'border-amber-500/10 hover:border-amber-500/30' },
  cyan: { bg: 'bg-cyan-500/10', text: 'text-cyan-400', border: 'border-cyan-500/10 hover:border-cyan-500/30' },
};
const c = colors[color] ?? colors.indigo;
---

<div
  class="reveal rounded-2xl border bg-deep-800/50 p-8 shadow-xl backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl group"
  class:list={[c.border]}
  style={`transition-delay: ${delay * 0.1}s`}
>
  <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${c.bg} ${c.text} text-lg`}>
    {icon}
  </div>
  <h3 class="mt-6 text-lg font-semibold text-white group-hover:text-indigo-300 transition-colors">{title}</h3>
  <p class="mt-2 text-sm text-gray-400 leading-relaxed">{description}</p>
</div>
