---
import Layout from '../layouts/Layout.astro';
import { ui } from '../i18n/ui';

const t = ui.fr.account;
---

<Layout title="Connexion" description={t.loginLede} pageKey="login" noindex>
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-xl">
      <div
        class="border border-vert/20 rounded-2xl overflow-hidden bg-white shadow-sm"
      >
        <!-- Terminal title bar -->
        <div
          class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-[#F8F8F6]"
        >
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-[#2d2a24]/70 font-medium"
            >olivier@otvt:~/login</span
          >
        </div>
        <!-- Content -->
        <div class="px-6 sm:px-12 py-8 sm:py-14">
          <p
            class="text-xs text-vert/85 font-mono mb-8 sm:mb-10 leading-relaxed"
          >
            <span class="text-vert font-semibold">olivier@otvt</span>:<span
              class="text-jaune">~</span
            ><span class="text-[#2d2a24]/70">$ </span><span
              class="text-[#2d2a24]/70">./login.sh</span
            >
          </p>
          <p
            class="text-xs font-medium tracking-[0.15em] text-vert/85 uppercase"
          >
            {t.loginEyebrow}
          </p>
          <h1 class="mt-4 text-4xl sm:text-5xl font-bold text-[#2d2a24]">
            {t.loginTitle}
          </h1>
          <p
            id="login-lede"
            class="mt-4 text-sm text-[#2d2a24]/70 leading-relaxed"
          >
            {t.loginLede}
          </p>

          <!-- Step 1: email -->
          <form id="login-form" class="mt-8 space-y-5">
            <div>
              <label
                for="email"
                class="block text-xs font-medium text-[#2d2a24]/70 mb-1"
                >{t.emailLabel}</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-[#F0EFEC] border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-[#2d2a24] placeholder-[#2d2a24]/30 transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                placeholder={t.emailPlaceholder}
              />
            </div>
            <button
              type="submit"
              class="inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span class="submit-label">{t.sendLink}</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
              >
            </button>
          </form>

          <!-- Step 2: code -->
          <form id="code-form" class="hidden mt-8 space-y-5">
            <div>
              <label
                for="code"
                class="block text-xs font-medium text-[#2d2a24]/70 mb-1"
                >{t.codeLabel}</label
              >
              <input
                type="text"
                inputmode="numeric"
                autocomplete="one-time-code"
                id="code"
                name="code"
                required
                class="w-full bg-[#F0EFEC] border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-[#2d2a24] tracking-[0.3em] placeholder-[#2d2a24]/30 transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                placeholder={t.codePlaceholder}
              />
            </div>
            <div class="flex items-center gap-4">
              <button
                type="submit"
                class="inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <span class="verify-label">{t.verifyCode}</span>
              </button>
              <button
                type="button"
                id="change-email"
                class="text-sm text-[#2d2a24]/70 hover:text-[#2d2a24] transition-colors"
              >
                {t.changeEmail}
              </button>
            </div>
          </form>

          <p
            id="login-status"
            class="mt-5 text-sm hidden"
            role="status"
            aria-live="polite"
          >
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script
  type="application/json"
  is:inline
  id="login-i18n"
  set:html={JSON.stringify(t)}
/>

<script>
  import { supabase } from '../lib/supabase';

  const t = JSON.parse(
    document.getElementById('login-i18n')?.textContent ?? '{}',
  );

  const accountPath = '/compte';

  async function redirectIfLoggedIn() {
    const {
      data: { session },
    } = await supabase.auth.getSession();
    if (session) window.location.href = accountPath;
  }

  function initLoginFlow() {
    const emailForm = document.getElementById(
      'login-form',
    ) as HTMLFormElement | null;
    const codeForm = document.getElementById(
      'code-form',
    ) as HTMLFormElement | null;
    const status = document.getElementById('login-status');
    const emailInput = document.getElementById(
      'email',
    ) as HTMLInputElement | null;
    const codeInput = document.getElementById(
      'code',
    ) as HTMLInputElement | null;
    const changeEmailButton = document.getElementById('change-email');
    if (
      !emailForm ||
      !codeForm ||
      !status ||
      !emailInput ||
      !codeInput ||
      !changeEmailButton
    )
      return;
    if (emailForm.dataset.initialized) return;
    emailForm.dataset.initialized = 'true';

    const emailSubmit = emailForm.querySelector('button[type="submit"]');
    const emailLabel = emailSubmit?.querySelector('.submit-label');
    const codeSubmit = codeForm.querySelector('button[type="submit"]');
    const codeLabel = codeSubmit?.querySelector('.verify-label');

    emailForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = emailInput.value.trim();
      if (!email || !emailSubmit || !emailLabel) return;

      emailSubmit.setAttribute('disabled', 'true');
      emailLabel.textContent = t.sending;
      status.classList.add('hidden');

      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: { shouldCreateUser: true },
      });

      if (error) {
        status.textContent = t.linkError;
        status.className = 'mt-5 text-sm text-red-600';
        status.classList.remove('hidden');
      } else {
        status.textContent = t.codeSent;
        status.className = 'mt-5 text-sm text-vert';
        status.classList.remove('hidden');
        emailForm.classList.add('hidden');
        codeForm.classList.remove('hidden');
        codeInput.focus();
      }

      emailSubmit.removeAttribute('disabled');
      emailLabel.textContent = t.sendLink;
    });

    codeForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = emailInput.value.trim();
      const code = codeInput.value.trim();
      if (!code || !codeSubmit || !codeLabel) return;

      codeSubmit.setAttribute('disabled', 'true');
      codeLabel.textContent = t.verifying;

      const { error } = await supabase.auth.verifyOtp({
        email,
        token: code,
        type: 'email',
      });

      if (error) {
        status.textContent = t.codeInvalid;
        status.className = 'mt-5 text-sm text-red-600';
        status.classList.remove('hidden');
        codeSubmit.removeAttribute('disabled');
        codeLabel.textContent = t.verifyCode;
      } else {
        window.location.href = accountPath;
      }
    });

    changeEmailButton.addEventListener('click', () => {
      codeForm.classList.add('hidden');
      emailForm.classList.remove('hidden');
      status.classList.add('hidden');
      codeForm.reset();
    });
  }

  redirectIfLoggedIn();
  initLoginFlow();
  document.addEventListener('astro:page-load', () => {
    redirectIfLoggedIn();
    initLoginFlow();
  });
</script>
