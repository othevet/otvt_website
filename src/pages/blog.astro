---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog">
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600">Blog</p>
        <h1 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Articles & tutoriels</h1>
        <p class="mt-4 text-lg text-gray-600">
          Développement web, WordPress, Astro, Next.js — je partage mon expérience et mes astuces.
        </p>
      </div>

      <div class="mt-16 text-center">
        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-12">
          <p class="text-gray-500">Aucun article pour le moment.</p>
          <p class="mt-2 text-sm text-gray-400">Bientôt des contenus sur WordPress, Astro, Next.js et le développement web en général.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
