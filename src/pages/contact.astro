---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <section class="pt-32 pb-24 sm:pb-32 px-6 sm:px-12 lg:px-16">
    <div class="mx-auto max-w-5xl">
      <div class="grid sm:grid-cols-2 gap-12 sm:gap-16">
        <div>
          <p class="reveal visible text-xs font-medium tracking-[0.15em] text-black/30 uppercase">Contact</p>
          <h1 class="reveal visible reveal-delay-1 mt-4 text-4xl sm:text-5xl font-['DM_Serif_Display',serif] text-[#1d1d1f]">Parlons de votre projet</h1>
          <p class="reveal visible reveal-delay-2 mt-4 text-sm text-black/40 leading-relaxed">Devis gratuit sous 48h. Remplissez le formulaire et je reviens vers vous rapidement.</p>
          <div class="reveal visible reveal-delay-3 mt-8 text-sm text-black/40 space-y-2">
            <p>contact@otvt.dev</p>
            <p>06 00 00 00 00</p>
            <p>Toulouse, France</p>
          </div>
        </div>
        <div>
          <form class="reveal visible space-y-5" data-netlify="true" name="contact" method="POST">
            <input type="hidden" name="form-name" value="contact" />
            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class="block text-xs font-medium text-black/40 mb-1">Nom</label>
                <input type="text" id="name" name="name" required class="w-full border border-black/10 rounded-lg px-4 py-2.5 text-sm text-[#1d1d1f] placeholder-black/30 transition-all duration-200 focus:outline-none focus:border-black/30" placeholder="Votre nom" />
              </div>
              <div>
                <label for="email" class="block text-xs font-medium text-black/40 mb-1">Email</label>
                <input type="email" id="email" name="email" required class="w-full border border-black/10 rounded-lg px-4 py-2.5 text-sm text-[#1d1d1f] placeholder-black/30 transition-all duration-200 focus:outline-none focus:border-black/30" placeholder="vous@exemple.fr" />
              </div>
            </div>
            <div>
              <label for="project-type" class="block text-xs font-medium text-black/40 mb-1">Type de projet</label>
              <select id="project-type" name="project-type" class="w-full border border-black/10 rounded-lg px-4 py-2.5 text-sm text-[#1d1d1f] transition-all duration-200 focus:outline-none focus:border-black/30">
                <option value="">Sélectionnez...</option>
                <option value="wordpress">WordPress</option>
                <option value="sur-mesure">Site sur mesure</option>
                <option value="maintenance">Maintenance / Évolution</option>
                <option value="autre">Autre</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-xs font-medium text-black/40 mb-1">Message</label>
              <textarea id="message" name="message" rows={5} required class="w-full border border-black/10 rounded-lg px-4 py-2.5 text-sm text-[#1d1d1f] placeholder-black/30 transition-all duration-200 focus:outline-none focus:border-black/30" placeholder="Parlez-moi de votre projet..."></textarea>
            </div>
            <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#1d1d1f] text-white text-sm font-medium rounded-full hover:bg-black/80 transition-all duration-200">
              Envoyer
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
