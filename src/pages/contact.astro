---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <div class="text-center">
        <p class="reveal visible text-sm font-semibold uppercase tracking-widest text-indigo-600">Contact</p>
        <h1 class="reveal visible reveal-delay-1 mt-4 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">Parlons de votre projet</h1>
        <p class="reveal visible reveal-delay-2 mt-4 text-lg text-gray-500">
          Devis gratuit sous 48h. Remplissez le formulaire ou écrivez-moi directement.
        </p>
      </div>

      <form class="reveal visible reveal-delay-2 mt-12 space-y-6" data-netlify="true" name="contact" method="POST">
        <input type="hidden" name="form-name" value="contact" />

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700">Nom *</label>
            <input type="text" id="name" name="name" required
              class="mt-1.5 block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm transition-all duration-200 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
              placeholder="Votre nom" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700">Email *</label>
            <input type="email" id="email" name="email" required
              class="mt-1.5 block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm transition-all duration-200 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
              placeholder="vous@exemple.fr" />
          </div>
        </div>

        <div>
          <label for="project-type" class="block text-sm font-medium text-gray-700">Type de projet</label>
          <select id="project-type" name="project-type"
            class="mt-1.5 block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-gray-900 shadow-sm transition-all duration-200 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
            <option value="">Sélectionnez...</option>
            <option value="wordpress">Site WordPress</option>
            <option value="sur-mesure">Site sur mesure (Next.js / Astro)</option>
            <option value="maintenance">Maintenance / Évolution</option>
            <option value="autre">Autre</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700">Message *</label>
          <textarea id="message" name="message" rows={5} required
            class="mt-1.5 block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm transition-all duration-200 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
            placeholder="Parlez-moi de votre projet..."></textarea>
        </div>

        <button type="submit"
          class="w-full rounded-xl bg-gray-900 px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-all duration-200 hover:bg-gray-800 hover:shadow-lg">
          Envoyer le message
        </button>
      </form>

      <div class="reveal visible reveal-delay-3 mt-12 border-t border-gray-100 pt-8 text-center">
        <p class="text-sm text-gray-500">
          Vous pouvez aussi m'écrire à <a href="mailto:contact@otvt.dev" class="font-medium text-indigo-600 hover:text-indigo-500 transition-colors">contact@otvt.dev</a>
        </p>
      </div>
    </div>
  </section>
</Layout>
