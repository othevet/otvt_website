---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <section class="px-4 sm:px-6 pt-20 pb-32 sm:pb-40">
    <div class="mx-auto max-w-4xl">
      <div class="grid sm:grid-cols-5 gap-4 sm:gap-8">
        <div class="sm:col-span-2">
          <div class="os-window border border-black/[0.04]">
            <div class="os-titlebar">
              <span class="os-dot red" />
              <span class="os-dot yellow" />
              <span class="os-dot green" />
              <span class="ml-3 text-xs text-black/25">Contact</span>
            </div>
            <div class="p-6 sm:p-8">
              <p class="text-xs font-medium tracking-widest text-black/30 uppercase">Contact</p>
              <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-[#1d1d1f]">Parlons de votre projet</h1>
              <p class="mt-3 text-sm text-black/40 leading-relaxed">
                Devis gratuit sous 48h. Remplissez le formulaire et je reviens vers vous rapidement.
              </p>
              <div class="mt-8 text-sm text-black/40 space-y-3">
                <p class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  contact@otvt.dev
                </p>
                <p class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  06 00 00 00 00
                </p>
                <p class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Toulouse, France
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="sm:col-span-3">
          <div class="os-window border border-black/[0.04]">
            <div class="os-titlebar">
              <span class="os-dot red" />
              <span class="os-dot yellow" />
              <span class="os-dot green" />
              <span class="ml-3 text-xs text-black/25">Nouveau message</span>
            </div>
            <div class="p-6 sm:p-8">
              <form data-netlify="true" name="contact" method="POST">
                <input type="hidden" name="form-name" value="contact" />
                <div class="space-y-5">
                  <div class="grid gap-5 sm:grid-cols-2">
                    <div>
                      <label for="name" class="block text-xs font-medium text-black/40 mb-1.5">Nom</label>
                      <input type="text" id="name" name="name" required
                        class="w-full bg-white border border-black/10 rounded-lg px-4 py-2.5 text-sm text-[#1d1d1f] placeholder-black/30 transition-all duration-200 focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20"
                        placeholder="Votre nom" />
                    </div>
                    <div>
                      <label for="email" class="block text-xs font-medium text-black/40 mb-1.5">Email</label>
                      <input type="email" id="email" name="email" required
                        class="w-full bg-white border border-black/10 rounded-lg px-4 py-2.5 text-sm text-[#1d1d1f] placeholder-black/30 transition-all duration-200 focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20"
                        placeholder="vous@exemple.fr" />
                    </div>
                  </div>

                  <div>
                    <label for="project-type" class="block text-xs font-medium text-black/40 mb-1.5">Type de projet</label>
                    <select id="project-type" name="project-type"
                      class="w-full bg-white border border-black/10 rounded-lg px-4 py-2.5 text-sm text-[#1d1d1f] transition-all duration-200 focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20">
                      <option value="">Sélectionnez...</option>
                      <option value="wordpress">WordPress</option>
                      <option value="sur-mesure">Site sur mesure</option>
                      <option value="maintenance">Maintenance / Évolution</option>
                      <option value="autre">Autre</option>
                    </select>
                  </div>

                  <div>
                    <label for="message" class="block text-xs font-medium text-black/40 mb-1.5">Message</label>
                    <textarea id="message" name="message" rows={5} required
                      class="w-full bg-white border border-black/10 rounded-lg px-4 py-2.5 text-sm text-[#1d1d1f] placeholder-black/30 transition-all duration-200 focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20"
                      placeholder="Parlez-moi de votre projet..."></textarea>
                  </div>

                  <button type="submit"
                    class="inline-flex items-center gap-2 px-6 py-2.5 bg-[#1d1d1f] text-white rounded-lg text-sm font-medium hover:bg-black transition-all duration-200">
                    Envoyer
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
