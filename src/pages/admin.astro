  function initInvoiceForm() {
    const form = document.getElementById(
      'invoice-form',
    ) as HTMLFormElement | null;
    const status = document.getElementById('invoice-form-status');
    const clientSelect = document.getElementById(
      'invoice-client-select',
    ) as HTMLSelectElement | null;
    const projectSelect = document.getElementById(
      'invoice-project-select',
    ) as HTMLSelectElement | null;
    const labelInput = document.getElementById(
      'invoice-label-input',
    ) as HTMLInputElement | null;
    const amountInput = document.getElementById(
      'invoice-amount-input',
    ) as HTMLInputElement | null;
    const dateInput = document.getElementById(
      'invoice-date-input',
    ) as HTMLInputElement | null;
    const fileInput = document.getElementById(
      'invoice-file-input',
    ) as HTMLInputElement | null;
    if (
      !form ||
      !status ||
      !clientSelect ||
      !projectSelect ||
      !labelInput ||
      !amountInput ||
      !dateInput ||
      !fileInput
    )
      return;
    if (form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const clientId = clientSelect.value;
      const label = labelInput.value.trim();
      const file = fileInput.files?.[0];
      if (!clientId || !label || !file || !dateInput.value) return;

      const submitButton = form.querySelector('button[type="submit"]');
      const submitLabel = submitButton?.querySelector('.submit-label');
      submitButton?.setAttribute('disabled', 'true');
      if (submitLabel) submitLabel.textContent = 'Envoi...';
      status.classList.add('hidden');

      const path = `${clientId}/${Date.now()}-${slugifyFilename(file.name)}`;
      const { error: uploadError } = await supabase.storage
        .from('invoices')
        .upload(path, file);

      if (uploadError) {
        status.textContent = "Erreur lors de l'upload du fichier.";
        status.className = 'text-sm text-danger sm:col-span-2';
        status.classList.remove('hidden');
        submitButton?.removeAttribute('disabled');
        if (submitLabel) submitLabel.textContent = 'Ajouter';
        return;
      }

      const { error } = await supabase.from('invoices').insert({
        client_id: clientId,
        project_id: projectSelect.value || null,
        label,
        amount: amountInput.value ? Number(amountInput.value) : null,
        issued_date: dateInput.value,
        file_path: path,
      });

      if (error) {
        status.textContent = "Erreur lors de l'ajout.";
        status.className = 'text-sm text-danger sm:col-span-2';
      } else {
        status.textContent = 'Facture ajoutée.';
        status.className = 'text-sm text-vert sm:col-span-2';
        form.reset();
        await loadInvoices();
      }
      status.classList.remove('hidden');
      submitButton?.removeAttribute('disabled');
      if (submitLabel) submitLabel.textContent = 'Ajouter';
    });
  }

  // --- Messages -----------------------------------------------------------

  function scrollThreadToBottom() {
    const thread = document.getElementById('admin-messages-thread');
    if (thread) thread.scrollTop = thread.scrollHeight;
  }

  function appendMessageBubble(message: Message) {
    const thread = document.getElementById('admin-messages-thread');
    const template = document.getElementById(
      'admin-message-bubble-template',
    ) as HTMLTemplateElement | null;
    if (!thread || !template) return;

    appendMessageBubbleToThread({
      supabase,
      thread,
      template,
      message,
      isOwn: message.sender === 'olivier',
      locale: 'fr-FR',
      downloadLabel: 'Télécharger',
      renderedMessageIds,
    });
  }

  function renderClientPicker() {
    const list = document.getElementById('admin-client-picker');
    const template = document.getElementById(
      'admin-client-picker-row-template',
    ) as HTMLTemplateElement | null;
    if (!list || !template) return;

    list.innerHTML = '';
    if (clients.length === 0) {
      showSection('admin-clients-empty');
      return;
    }
    hideSection('admin-clients-empty');

    for (const client of clients) {
      const node = template.content.cloneNode(true) as DocumentFragment;
      node.querySelector('.client-name')!.textContent = client.name;
      const button = node.querySelector('.picker-button') as HTMLButtonElement;
      const dot = node.querySelector('.unread-dot') as HTMLElement;
      if ((unreadCounts.get(client.id) ?? 0) > 0) dot.classList.remove('hidden');
      if (client.id === selectedClientId) {
        button.classList.add('bg-hairline', 'text-ink');
      }
      button.addEventListener('click', () => openThread(client.id));
      list.appendChild(node);
    }
  }

  async function openThread(clientId: string) {
    selectedClientId = clientId;
    unreadCounts.delete(clientId);
    renderClientPicker();
    updateMessagesTabBadge();

    showSection('admin-messages-thread');
    showSection('admin-message-form');
    hideSection('admin-thread-empty');

    const thread = document.getElementById('admin-messages-thread');
    if (thread) thread.innerHTML = '';
    renderedMessageIds.clear();

    const { data: messages } = await supabase
      .from('messages')
      .select(MESSAGE_COLUMNS)
      .eq('client_id', clientId)
      .order('created_at', { ascending: true });

    for (const message of (messages ?? []) as Message[]) {
      appendMessageBubble(message);
    }
    scrollThreadToBottom();

    await supabase
      .from('messages')
      .update({ read_at: new Date().toISOString() })
      .eq('client_id', clientId)
      .eq('sender', 'client')
      .is('read_at', null);
  }

  function initAdminMessageForm() {
    const form = document.getElementById(
      'admin-message-form',
    ) as HTMLFormElement | null;
    const status = document.getElementById('admin-message-status');
    const textarea = document.getElementById(
      'admin-message-body',
    ) as HTMLTextAreaElement | null;
    const fileInput = document.getElementById(
      'admin-message-file',
    ) as HTMLInputElement | null;
    if (!form || !status || !textarea || !fileInput) return;
    if (form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const body = textarea.value.trim();
      const file = fileInput.files?.[0] ?? null;
      if ((!body && !file) || !selectedClientId) return;

      if (file && file.size > MAX_ATTACHMENT_SIZE) {
        status.textContent = 'Fichier trop volumineux (10 Mo maximum).';
        status.className = 'text-sm text-danger';
        status.classList.remove('hidden');
        return;
      }
      status.classList.add('hidden');

      let attachmentPath: string | null = null;
      if (file) {
        const path = `${selectedClientId}/${Date.now()}-${slugifyFilename(file.name)}`;
        const { error: uploadError } = await supabase.storage
          .from('message-attachments')
          .upload(path, file);
        if (uploadError) {
          status.textContent = "Erreur lors de l'upload du fichier.";
          status.className = 'text-sm text-danger';
          status.classList.remove('hidden');
          return;
        }
        attachmentPath = path;
      }

      const { data, error } = await supabase
        .from('messages')
        .insert({
          client_id: selectedClientId,
          sender: 'olivier',
          body: body || null,
          attachment_path: attachmentPath,
          attachment_name: file?.name ?? null,
          attachment_mime: file?.type ?? null,
        })
        .select(MESSAGE_COLUMNS)
        .single();

      if (!error && data) {
        appendMessageBubble(data as Message);
        scrollThreadToBottom();
        form.reset();
      } else {
        status.textContent = "Erreur lors de l'envoi.";
        status.className = 'text-sm text-danger';
        status.classList.remove('hidden');
      }
    });
  }

  function subscribeAdminInbox() {
    if (adminChannel) return;
    adminChannel = supabase
      .channel('admin-messages-inbox')
      .on(
        'postgres_changes',
        { event: 'INSERT', schema: 'public', table: 'messages' },
        (payload) => {
          const message = payload.new as Message;
          if (message.sender === 'olivier') return;
          if (renderedMessageIds.has(message.id)) return;
          if (message.client_id === selectedClientId) {
            appendMessageBubble(message);
            scrollThreadToBottom();
            supabase
              .from('messages')
              .update({ read_at: new Date().toISOString() })
              .eq('id', message.id);
          } else {
            unreadCounts.set(
              message.client_id,
              (unreadCounts.get(message.client_id) ?? 0) + 1,
            );
            renderClientPicker();
            updateMessagesTabBadge();
          }
        },
      )
      .subscribe();
  }

  // --- Prospects -----------------------------------------------------------

  function updateProspectsTabBadge(prospects: Prospect[]) {
    const badge = document.getElementById('prospects-tab-badge');
    if (!badge) return;
    const today = todayISO();
    const overdue = prospects.filter(
      (p) =>
        !!p.next_follow_up &&
        p.next_follow_up < today &&
        p.status !== 'gagne' &&
        p.status !== 'perdu',
    ).length;
    badge.textContent = String(overdue);
    badge.classList.toggle('hidden', overdue === 0);
  }

  async function loadProspects() {
    const { data } = await supabase
      .from('prospects')
      .select('id, name, email, status, notes, next_follow_up')
      .order('next_follow_up', { ascending: true, nullsFirst: false });
    renderProspectsList((data ?? []) as Prospect[]);
  }

  function renderProspectsList(allProspects: Prospect[]) {
    const list = document.getElementById('prospects-list');
    const template = document.getElementById(
      'admin-prospect-row-template',
    ) as HTMLTemplateElement | null;
    const filterSelect = document.getElementById(
      'prospect-filter-select',
    ) as HTMLSelectElement | null;
    if (!list || !template) return;

    updateProspectsTabBadge(allProspects);

    const filter = filterSelect?.value ?? '';
    const prospects = filter
      ? allProspects.filter((p) => p.status === filter)
      : allProspects;

    list.innerHTML = '';
    if (prospects.length === 0) {
      showSection('prospects-empty');
      return;
    }
    hideSection('prospects-empty');

    const today = todayISO();
    for (const prospect of prospects) {
      const node = template.content.cloneNode(true) as DocumentFragment;
      node.querySelector('.prospect-name')!.textContent = prospect.name;
      node.querySelector('.prospect-email')!.textContent =
        prospect.email ?? '';

      const followupEl = node.querySelector(
        '.prospect-followup',
      ) as HTMLElement;
      const isOverdue =
        !!prospect.next_follow_up &&
        prospect.next_follow_up < today &&
        prospect.status !== 'gagne' &&
        prospect.status !== 'perdu';
      if (prospect.next_follow_up) {
        followupEl.textContent = `Relance : ${formatDate(prospect.next_follow_up)}`;
        followupEl.classList.add(isOverdue ? 'text-danger' : 'text-ink/70');
        if (isOverdue) followupEl.classList.add('font-semibold');
      }

      const statusSelect = node.querySelector(
        '.status-select',
      ) as HTMLSelectElement;
      statusSelect.value = prospect.status;
      statusSelect.addEventListener('change', async () => {
        await supabase
          .from('prospects')
          .update({ status: statusSelect.value })
          .eq('id', prospect.id);
        await loadProspects();
      });

      const deleteButton = node.querySelector(
        '.delete-button',
      ) as HTMLButtonElement;
      deleteButton.addEventListener('click', async () => {
        if (!confirm(`Supprimer le prospect "${prospect.name}" ?`)) return;
        await supabase.from('prospects').delete().eq('id', prospect.id);
        await loadProspects();
      });

      list.appendChild(node);
    }
  }

