  // --- Tasks -----------------------------------------------------------

  function populateTaskProjectSelects() {
    const options = projects.map((project) => ({
      value: project.id,
      label: `${project.clients?.name ?? ''} — ${project.name}`,
    }));

    const formSelect = document.getElementById(
      'task-project-select',
    ) as HTMLSelectElement | null;
    if (formSelect) {
      const current = formSelect.value;
      formSelect.innerHTML = '<option value="">Choisir un projet</option>';
      for (const { value, label } of options) {
        const option = document.createElement('option');
        option.value = value;
        option.textContent = label;
        formSelect.appendChild(option);
      }
      formSelect.value = current;
    }

    const filterSelect = document.getElementById(
      'task-filter-select',
    ) as HTMLSelectElement | null;
    if (filterSelect) {
      const current = filterSelect.value;
      filterSelect.innerHTML = '<option value="">Tous les projets</option>';
      for (const { value, label } of options) {
        const option = document.createElement('option');
        option.value = value;
        option.textContent = label;
        filterSelect.appendChild(option);
      }
      filterSelect.value = current;
    }
  }

  async function loadTasks() {
    const { data } = await supabase
      .from('tasks')
      .select('id, project_id, title, done, due_date, priority, projects(name, clients(name))')
      .order('due_date', { ascending: true, nullsFirst: false });
    renderTasksList((data ?? []) as unknown as Task[]);
  }

  function renderTaskRow(
    template: HTMLTemplateElement,
    task: Task,
    today: string,
  ) {
    const node = template.content.cloneNode(true) as DocumentFragment;

    const titleEl = node.querySelector('.task-title') as HTMLElement;
    titleEl.textContent = task.title;
    if (task.done) titleEl.classList.add('line-through', 'text-ink/40');

    const dueEl = node.querySelector('.task-due') as HTMLElement;
    const isOverdue = !!task.due_date && task.due_date < today && !task.done;
    if (task.due_date) {
      dueEl.textContent = `Échéance : ${formatDate(task.due_date)}`;
      dueEl.classList.add(isOverdue ? 'text-danger' : 'text-ink/70');
      if (isOverdue) dueEl.classList.add('font-semibold');
    }

    const priorityEl = node.querySelector('.task-priority') as HTMLElement;
    priorityEl.textContent = PRIORITY_LABELS[task.priority];
    priorityEl.classList.add(...PRIORITY_CLASSES[task.priority]);

    const checkbox = node.querySelector('.done-checkbox') as HTMLInputElement;
    checkbox.checked = task.done;
    checkbox.addEventListener('change', async () => {
      await supabase
        .from('tasks')
        .update({ done: checkbox.checked })
        .eq('id', task.id);
      await loadTasks();
    });

    const deleteButton = node.querySelector(
      '.delete-button',
    ) as HTMLButtonElement;
    deleteButton.addEventListener('click', async () => {
      if (!confirm(`Supprimer la tâche "${task.title}" ?`)) return;
      await supabase.from('tasks').delete().eq('id', task.id);
      await loadTasks();
    });

    return node;
  }

  function renderTasksList(allTasks: Task[]) {
    const list = document.getElementById('tasks-list');
    const template = document.getElementById(
      'admin-task-row-template',
    ) as HTMLTemplateElement | null;
    const filterSelect = document.getElementById(
      'task-filter-select',
    ) as HTMLSelectElement | null;
    if (!list || !template) return;

    const filter = filterSelect?.value ?? '';
    const tasks = filter
      ? allTasks.filter((t) => t.project_id === filter)
      : allTasks;

    list.innerHTML = '';
    if (tasks.length === 0) {
      showSection('tasks-empty');
      return;
    }
    hideSection('tasks-empty');

    const today = todayISO();

    if (filter) {
      const ul = document.createElement('ul');
      ul.className = 'space-y-3';
      for (const task of tasks) ul.appendChild(renderTaskRow(template, task, today));
      list.appendChild(ul);
      return;
    }

    const groups = new Map<string, Task[]>();
    for (const task of tasks) {
      const label = task.projects
        ? `${task.projects.clients?.name ?? ''} — ${task.projects.name}`
        : 'Projet supprimé';
      if (!groups.has(label)) groups.set(label, []);
      groups.get(label)!.push(task);
    }

    for (const [label, groupTasks] of groups) {
      const heading = document.createElement('p');
      heading.className =
        'text-xs font-semibold text-ink/70 uppercase tracking-wide mt-6 first:mt-0';
      heading.textContent = label;
      list.appendChild(heading);

      const ul = document.createElement('ul');
      ul.className = 'mt-2 space-y-3';
      for (const task of groupTasks)
        ul.appendChild(renderTaskRow(template, task, today));
      list.appendChild(ul);
    }
  }

  function initTaskForm() {
    const form = document.getElementById(
      'task-form',
    ) as HTMLFormElement | null;
    const status = document.getElementById('task-form-status');
    const projectSelect = document.getElementById(
      'task-project-select',
    ) as HTMLSelectElement | null;
    const titleInput = document.getElementById(
      'task-title-input',
    ) as HTMLInputElement | null;
    const prioritySelect = document.getElementById(
      'task-priority-select',
    ) as HTMLSelectElement | null;
    const dueInput = document.getElementById(
      'task-due-input',
    ) as HTMLInputElement | null;
    if (
      !form ||
      !status ||
      !projectSelect ||
      !titleInput ||
      !prioritySelect ||
      !dueInput
    )
      return;
    if (form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const projectId = projectSelect.value;
      const title = titleInput.value.trim();
      if (!projectId || !title) return;

      const { error } = await supabase.from('tasks').insert({
        project_id: projectId,
        title,
        priority: prioritySelect.value,
        due_date: dueInput.value || null,
      });
      if (error) {
        status.textContent = "Erreur lors de l'ajout.";
        status.className = 'text-sm text-danger sm:col-span-2';
      } else {
        status.textContent = 'Tâche ajoutée.';
        status.className = 'text-sm text-vert sm:col-span-2';
        form.reset();
        await loadTasks();
      }
      status.classList.remove('hidden');
    });
  }

  function initTaskFilter() {
    const select = document.getElementById(
      'task-filter-select',
    ) as HTMLSelectElement | null;
    if (!select || select.dataset.initialized) return;
    select.dataset.initialized = 'true';
    select.addEventListener('change', () => loadTasks());
  }

  // --- Auth -----------------------------------------------------------

  function initBackToLogin() {
    const button = document.getElementById('admin-back-to-login');
    if (!button || button.dataset.initialized) return;
    button.dataset.initialized = 'true';
    button.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = loginPath;
    });
  }

  function initLogout() {
    const button = document.getElementById('admin-logout-button');
    if (!button || button.dataset.initialized) return;
    button.dataset.initialized = 'true';
    button.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = loginPath;
    });
  }

  async function init() {
    hideSection('admin-content');
    hideSection('admin-unauthorized');
    showSection('admin-checking');
    initBackToLogin();

    const {
      data: { session },
    } = await supabase.auth.getSession();

    const unauthorizedMessage = document.getElementById(
      'admin-unauthorized-message',
    );

    if (!session) {
      if (unauthorizedMessage)
        unauthorizedMessage.textContent =
          'Vous devez vous connecter pour accéder à cet espace.';
      hideSection('admin-checking');
      showSection('admin-unauthorized');
      return;
    }

    if (session.user.email?.toLowerCase() !== ADMIN_EMAIL) {
      if (unauthorizedMessage)
        unauthorizedMessage.textContent =
          "Cet espace est réservé à l'administrateur.";
      hideSection('admin-checking');
      showSection('admin-unauthorized');
      return;
    }

    initTabs();
    initClientForm();
    initProjectForm();
    initInvoiceForm();
    initAdminMessageForm();
    initProspectForm();
    initProspectFilter();
    initTaskForm();
    initTaskFilter();
    initLogout();

    await loadClients();
    await Promise.all([loadProjects(), loadInvoices(), loadUnreadCounts()]);
    await Promise.all([loadProspects(), loadTasks()]);
    subscribeAdminInbox();

    hideSection('admin-checking');
    showSection('admin-content');
  }

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => {
    if (adminChannel) {
      supabase.removeChannel(adminChannel);
      adminChannel = null;
    }
  });
</script>
