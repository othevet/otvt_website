---
import Layout from '../layouts/Layout.astro';
import TerminalHero from '../components/TerminalHero.astro';
import CommandCard from '../components/CommandCard.astro';
import Neofetch from '../components/Neofetch.astro';
import CtaTerminal from '../components/CtaTerminal.astro';
---

<Layout>
  <TerminalHero />

  <section class="relative border-t border-white/5 py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="reveal text-xs font-semibold uppercase tracking-widest text-indigo-400 font-['JetBrains_Mono',monospace]">// commands</p>
        <h2 class="reveal reveal-delay-1 mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl font-['Inter',sans-serif]">Services</h2>
      </div>

      <div class="mt-16 grid gap-4 sm:grid-cols-2">
        <CommandCard
          command="$ wordpress"
          description="Sites WordPress sur mesure"
          tags={['theme', 'woo', 'plugin', 'perf']}
          color="indigo"
          delay={0}
        />
        <CommandCard
          command="$ custom"
          description="Apps Next.js / Astro / React"
          tags={['nextjs', 'astro', 'tailwind', 'typescript']}
          color="purple"
          delay={1}
        />
        <CommandCard
          command="$ maintain"
          description="Maintenance, sécurité, mise à jour"
          tags={['audit', 'secu', 'migration', 'speed']}
          color="amber"
          delay={2}
        />
        <CommandCard
          command="$ consult"
          description="Architecture, stack, mentoring"
          tags={['stack', 'review', 'archi', 'mentoring']}
          color="cyan"
          delay={3}
        />
      </div>

      <div class="reveal mt-8 text-center">
        <a href="/services" class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-['JetBrains_Mono',monospace] text-gray-400 transition-all duration-200 hover:bg-white/10 hover:text-white">
          ❯ man services <span class="text-xs text-gray-600">pour plus de détails</span>
        </a>
      </div>
    </div>
  </section>

  <Neofetch />
  <CtaTerminal />
</Layout>
