---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-indigo-50 via-white to-purple-50" />
    <div class="mx-auto max-w-6xl px-4 pb-20 pt-20 sm:px-6 sm:pb-28 sm:pt-32">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-6xl">
          Votre partenaire
          <span class="bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">développement web</span>
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-600 sm:text-xl">
          WordPress, sites vitrines, applications sur mesure. Je crée des solutions web performantes qui propulsent votre activité.
        </p>
        <div class="mt-10 flex items-center justify-center gap-4">
          <a href="/contact" class="rounded-xl bg-indigo-600 px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-all duration-200 hover:bg-indigo-500 hover:shadow-lg">
            Démarrer un projet
          </a>
          <a href="/services" class="rounded-xl border border-gray-300 bg-white px-8 py-3.5 text-base font-semibold text-gray-700 transition-all duration-200 hover:bg-gray-50">
            Voir les services
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-gray-100 bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600">Services</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Ce que je fais</h2>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-200 hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-100 text-indigo-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </div>
          <h3 class="mt-6 text-lg font-semibold text-gray-900">WordPress</h3>
          <p class="mt-2 text-sm text-gray-500">Thèmes et plugins sur mesure, WooCommerce, maintenance, optimisation.</p>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-200 hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-purple-100 text-purple-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
          </div>
          <h3 class="mt-6 text-lg font-semibold text-gray-900">Sites sur mesure</h3>
          <p class="mt-2 text-sm text-gray-500">Next.js, Astro, React — des sites ultra-rapides, modernes et scalables.</p>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-200 hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-amber-100 text-amber-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="mt-6 text-lg font-semibold text-gray-900">Maintenance & SEO</h3>
          <p class="mt-2 text-sm text-gray-500">Audit technique, optimisation des performances, référencement naturel.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Pourquoi moi ?</h2>
        <p class="mt-4 text-lg text-gray-600">
          Développeur indépendant, je combine expertise technique et vision métier pour livrer des projets qui tiennent la route.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="text-4xl font-extrabold text-indigo-600">10+</div>
          <h3 class="mt-2 text-lg font-semibold text-gray-900">Projets livrés</h3>
          <p class="mt-1 text-sm text-gray-500">Sites vitrines, e-commerce et apps sur mesure.</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-indigo-600">100%</div>
          <h3 class="mt-2 text-lg font-semibold text-gray-900">Satisfait ou corrigé</h3>
          <p class="mt-1 text-sm text-gray-500">Je ne lâche pas tant que le résultat n'est pas parfait.</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-indigo-600">24h</div>
          <h3 class="mt-2 text-lg font-semibold text-gray-900">Délai de réponse</h3>
          <p class="mt-1 text-sm text-gray-500">Je réponds sous 24h, même le week-end.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Prêt à lancer votre projet ?</h2>
      <p class="mt-3 text-lg text-indigo-200">
        Discutons de vos besoins sans engagement. Devis gratuit sous 48h.
      </p>
      <a href="/contact" class="mt-8 inline-block rounded-xl bg-white px-8 py-3.5 text-base font-semibold text-indigo-600 shadow-sm transition-all duration-200 hover:bg-indigo-50 hover:shadow-lg">
        Me contacter
      </a>
    </div>
  </section>
</Layout>
