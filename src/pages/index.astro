---
import Layout from '../layouts/Layout.astro';
import TypingHero from '../components/TypingHero.astro';
import AnimatedCard from '../components/AnimatedCard.astro';
---

<Layout>
  <TypingHero />

  <section class="relative border-t border-white/5 bg-deep-800/50 py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="reveal text-xs font-semibold uppercase tracking-widest text-indigo-400">Services</p>
        <h2 class="reveal reveal-delay-1 mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">Ce que je fais</h2>
        <p class="reveal reveal-delay-2 mt-4 text-gray-400">
          Du WordPress à l'application moderne, je couvre tout le spectre du développement web.
        </p>
      </div>

      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <AnimatedCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>'
          title="WordPress"
          description="Thèmes sur mesure, WooCommerce, plugins, optimisation et maintenance."
          color="indigo"
          delay={0}
        />
        <AnimatedCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>'
          title="Sites sur mesure"
          description="Next.js, Astro, React — des sites ultra-rapides, modernes et scalables."
          color="purple"
          delay={1}
        />
        <AnimatedCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>'
          title="Maintenance & SEO"
          description="Audit technique, optimisation des performances, référencement naturel."
          color="amber"
          delay={2}
        />
        <AnimatedCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>'
          title="Consulting & Conseil"
          description="Architecture technique, choix technologiques, audit de code et mentoring."
          color="cyan"
          delay={3}
        />
      </div>
    </div>
  </section>

  <section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-indigo-600/5 via-transparent to-purple-600/5 -z-10" />
    
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="reveal text-3xl font-bold tracking-tight text-white sm:text-4xl">Pourquoi moi ?</h2>
        <p class="reveal reveal-delay-1 mt-4 text-gray-400">
          Développeur indépendant, je combine expertise technique et vision métier.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-3">
        <div class="reveal reveal-delay-1 text-center">
          <div class="text-5xl font-extrabold bg-gradient-to-b from-indigo-400 to-purple-400 bg-clip-text text-transparent">10+</div>
          <h3 class="mt-3 text-lg font-semibold text-white">Projets livrés</h3>
          <p class="mt-1 text-sm text-gray-500">Sites vitrines, e-commerce et apps sur mesure.</p>
        </div>
        <div class="reveal reveal-delay-2 text-center">
          <div class="text-5xl font-extrabold bg-gradient-to-b from-indigo-400 to-purple-400 bg-clip-text text-transparent">100%</div>
          <h3 class="mt-3 text-lg font-semibold text-white">Satisfait ou corrigé</h3>
          <p class="mt-1 text-sm text-gray-500">Je ne lâche pas tant que le résultat n'est pas parfait.</p>
        </div>
        <div class="reveal reveal-delay-3 text-center">
          <div class="text-5xl font-extrabold bg-gradient-to-b from-indigo-400 to-purple-400 bg-clip-text text-transparent">24h</div>
          <h3 class="mt-3 text-lg font-semibold text-white">Délai de réponse</h3>
          <p class="mt-1 text-sm text-gray-500">Je réponds sous 24h, même le week-end.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-24 sm:py-32">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/10 via-deep-900 to-purple-600/10 -z-10" />
    <div class="absolute inset-0 -z-10 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,.3) 1px, transparent 0); background-size: 40px 40px;" />
    
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="reveal text-3xl font-bold text-white sm:text-4xl">Prêt à donner vie à votre projet ?</h2>
      <p class="reveal reveal-delay-1 mt-4 text-lg text-gray-400">
            On en discute 30 minutes sans engagement. Devis gratuit sous 48h.
      </p>
      <a href="/contact" class="reveal reveal-delay-2 mt-8 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-8 py-3.5 text-base font-semibold text-white shadow-xl shadow-indigo-500/25 transition-all duration-200 hover:shadow-indigo-500/50 hover:scale-[1.02]">
        Me contacter
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Layout>
