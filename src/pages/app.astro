---
import Layout from '../layouts/Layout.astro';
---

<Layout title="App">
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="border border-vert/20 rounded-2xl overflow-hidden bg-white shadow-sm">
        <!-- Terminal title bar -->
        <div class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-[#F8F8F6]">
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]" />
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]" />
          <span class="w-3 h-3 rounded-full bg-[#28c840]" />
          <span class="ml-3 text-xs text-[#2d2a24]/30 font-medium">olivier@otvt:~/apps</span>
        </div>
        <!-- Content -->
        <div class="px-6 sm:px-12 py-8 sm:py-14">
          <p class="text-xs text-vert/70 font-mono mb-8 sm:mb-10 leading-relaxed">
            <span class="text-vert font-semibold">olivier@otvt</span>:<span class="text-jaune">~</span><span class="text-[#2d2a24]/25">$ </span><span class="text-[#2d2a24]/40">ls -la projects/</span>
          </p>

          <p class="text-xs font-medium tracking-[0.15em] text-vert/80 uppercase mb-6">Réalisations</p>
          <h1 class="text-4xl sm:text-5xl font-bold text-[#2d2a24]">Ce que j'ai construit</h1>
          <p class="mt-4 text-sm text-[#2d2a24]/50 leading-relaxed max-w-lg">Des projets web, du WordPress aux applications sur mesure. Chaque ligne de code raconte une histoire.</p>

          <div class="mt-12 grid sm:grid-cols-2 gap-6">
            <!-- Projet 1 -->
            <a href="https://disneyday-website.vercel.app/" target="_blank" rel="noopener noreferrer" class="border border-vert/10 rounded-xl p-6 hover:border-vert/30 transition-colors block group">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-2 h-2 rounded-full bg-vert" />
                <span class="text-xs text-vert/60 font-mono">site-web</span>
              </div>
              <h3 class="text-lg font-semibold text-[#2d2a24] group-hover:text-vert transition-colors">DisneyDay</h3>
              <p class="mt-2 text-sm text-[#2d2a24]/50 leading-relaxed">Calendrier interactif de l'histoire Disney. Chaque jour, découvrez les sorties, anniversaires et événements marquants — avec agenda, catalogue et blog.</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">Next.js</span>
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">Tailwind</span>
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">Vercel</span>
              </div>
            </a>

            <!-- Projet 2 -->
            <div class="border border-vert/10 rounded-xl p-6 hover:border-vert/30 transition-colors">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-2 h-2 rounded-full bg-jaune" />
                <span class="text-xs text-vert/60 font-mono">wordpress</span>
              </div>
              <h3 class="text-lg font-semibold text-[#2d2a24]">Projet à venir</h3>
              <p class="mt-2 text-sm text-[#2d2a24]/50 leading-relaxed">Description du projet — stack, objectifs, résultats.</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">WordPress</span>
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">WooCommerce</span>
              </div>
            </div>

            <!-- Projet 3 -->
            <div class="border border-vert/10 rounded-xl p-6 hover:border-vert/30 transition-colors">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-2 h-2 rounded-full bg-vert" />
                <span class="text-xs text-vert/60 font-mono">application</span>
              </div>
              <h3 class="text-lg font-semibold text-[#2d2a24]">Projet à venir</h3>
              <p class="mt-2 text-sm text-[#2d2a24]/50 leading-relaxed">Description du projet — stack, objectifs, résultats.</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">Next.js</span>
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">PostgreSQL</span>
              </div>
            </div>

            <!-- Projet 4 -->
            <div class="border border-vert/10 rounded-xl p-6 hover:border-vert/30 transition-colors">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-2 h-2 rounded-full bg-jaune" />
                <span class="text-xs text-vert/60 font-mono">maintenance</span>
              </div>
              <h3 class="text-lg font-semibold text-[#2d2a24]">Projet à venir</h3>
              <p class="mt-2 text-sm text-[#2d2a24]/50 leading-relaxed">Description du projet — stack, objectifs, résultats.</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">Audit</span>
                <span class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full">Performance</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>