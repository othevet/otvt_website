---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import meImage from '../assets/me.png';
---

<Layout title="À propos">
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-7xl">
      <div
        class="border border-vert/20 rounded-2xl overflow-hidden bg-white shadow-sm"
      >
        <div
          class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-[#F8F8F6]"
        >
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-[#2d2a24]/30 font-medium"
            >olivier@otvt:~/about</span
          >
        </div>
        <div class="px-6 sm:px-12 py-8 sm:py-14">
          <p
            class="text-xs text-vert/70 font-mono mb-8 sm:mb-10 leading-relaxed"
          >
            <span class="text-vert font-semibold">olivier@otvt</span>:<span
              class="text-jaune">~</span
            ><span class="text-[#2d2a24]/25">$ </span><span
              class="text-[#2d2a24]/40">cat about.md</span
            >
          </p>
          <div class="grid sm:grid-cols-2 gap-12 sm:gap-16 items-center">
            <div>
              <p
                class="text-xs font-medium tracking-[0.15em] text-vert/80 uppercase mb-6"
              >
                À propos
              </p>
              <h1 class="text-4xl sm:text-5xl font-bold text-[#2d2a24]">
                Développeur web passionné
              </h1>
              <div
                class="mt-6 space-y-4 text-sm text-[#2d2a24]/50 leading-relaxed"
              >
                <p>
                  Je suis <strong class="text-[#2d2a24]">Olivier</strong>,
                  passionné d'informatique et de nouvelles technologies.
                  Technicien informatique pendant plus de 10 ans, tout en
                  continuant de m'intéresser au développement, j'ai décidé de me
                  lancer seul dans cette aventure.
                </p>
                <p>
                  Ce qui me motive ? <strong class="text-[#2d2a24]"
                    >Donner vie à vos idées</strong
                  >. Chaque projet est une nouvelle histoire à écrire.
                </p>
                <p>
                  En solo, je travaille sans intermédiaire : vous parlez
                  directement au développeur. Pas de commercial, pas de chef de
                  projet, pas de surprises.
                </p>
              </div>
            </div>
            <div class="flex justify-center sm:justify-end">
              <div class="relative">
                <div
                  class="absolute -inset-6 bg-jaune/20 rounded-full blur-3xl"
                >
                </div>
                <div class="relative w-64 h-64 sm:w-72 sm:h-72">
                  <Image
                    src={meImage}
                    alt="Olivier Thévet"
                    width={288}
                    height={288}
                    class="w-full h-full rounded-full object-cover object-top shadow-xl"
                    loading="eager"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
