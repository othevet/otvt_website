---
import Layout from '../layouts/Layout.astro';
import { ui } from '../i18n/ui';

const t = ui.fr.account;
---

<Layout
  title="Mon compte"
  description={t.accountTitle}
  pageKey="account"
  noindex
>
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-4xl space-y-8">
      <!-- Checking session -->
      <div
        id="account-checking"
        class="border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
      >
        <div class="px-6 sm:px-12 py-14 text-center">
          <p class="text-sm text-ink/70 font-mono">
            {t.checkingSession}
          </p>
        </div>
      </div>

      <!-- Not logged in -->
      <div
        id="account-guest"
        class="hidden border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
      >
        <div class="px-6 sm:px-12 py-14 text-center">
          <p id="account-guest-message" class="text-sm text-ink/70">
            {t.notLoggedIn}
          </p>
          <button
            id="guest-back-to-login"
            type="button"
            class="mt-6 inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm"
          >
            {t.backToLogin}
          </button>
        </div>
      </div>

      <!-- Signed-in content -->
      <div id="account-content" class="hidden space-y-8">
        <!-- Header -->
        <div
          class="border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
        >
          <div
            class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-surface-alt"
          >
            <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
            <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
            <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
            <span class="ml-3 text-xs text-ink/70 font-medium"
              >olivier@otvt:~/compte</span
            >
          </div>
          <div
            class="px-6 sm:px-12 py-8 sm:py-10 flex items-center justify-between gap-4"
          >
            <div>
              <p
                class="text-xs font-medium tracking-[0.15em] text-vert/85 uppercase"
              >
                {t.accountEyebrow}
              </p>
              <h1 class="mt-3 text-3xl sm:text-4xl font-bold text-ink">
                {t.accountTitle}{' '}<span id="client-name"></span>
              </h1>
            </div>
            <button
              id="logout-button"
              type="button"
              class="shrink-0 px-4 py-2 text-xs font-semibold rounded-full border border-vert/20 text-ink/70 hover:text-vert hover:border-vert/40 transition-colors"
            >
              {t.logout}
            </button>
          </div>
        </div>

        <!-- Projects -->
        <div
          class="border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
        >
          <div class="px-6 sm:px-12 py-8 sm:py-10">
            <h2 class="text-lg font-semibold text-ink">
              {t.projectsTitle}
            </h2>
            <p
              id="projects-empty"
              class="hidden mt-3 text-sm text-ink/70"
            >
              {t.noProjects}
            </p>
            <ul id="projects-list" class="mt-4 space-y-3"></ul>
          </div>
        </div>

        <!-- Invoices -->
        <div
          class="border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
        >
          <div class="px-6 sm:px-12 py-8 sm:py-10">
            <h2 class="text-lg font-semibold text-ink">
              {t.invoicesTitle}
            </h2>
            <p
              id="invoices-empty"
              class="hidden mt-3 text-sm text-ink/70"
            >
              {t.noInvoices}
            </p>
            <ul id="invoices-list" class="mt-4 space-y-3"></ul>
          </div>
        </div>

        <!-- Message -->
        <div
          class="border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
        >
          <div class="px-6 sm:px-12 py-8 sm:py-10">
            <h2 class="text-lg font-semibold text-ink">
              {t.messagesTitle}
            </h2>
            <p
              id="messages-empty"
              class="hidden mt-3 text-sm text-ink/70"
            >
              {t.messagesEmpty}
            </p>
            <ul
              id="messages-thread"
              class="mt-4 max-h-96 overflow-y-auto space-y-2 pr-1"
            ></ul>
            <form id="message-form" class="mt-4 space-y-3">
              <textarea
                id="message-body"
                name="message"
                rows={3}
                required
                class="w-full bg-bg border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-ink placeholder-[#2d2a24]/30 transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                placeholder={t.messagePlaceholder}></textarea>
              <button
                type="submit"
                class="inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <span class="submit-label">{t.send}</span>
              </button>
              <p
                id="message-status"
                class="text-sm hidden"
                role="status"
                aria-live="polite"
              >
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<!-- Row templates -->
<template id="project-row-template">
  <li
    class="flex items-center justify-between gap-4 border-b border-vert/10 pb-3 last:border-0 last:pb-0"
  >
    <span class="text-sm text-ink project-name"></span>
    <span class="text-xs font-medium px-3 py-1 rounded-full project-status"
    ></span>
  </li>
</template>

<template id="invoice-row-template">
  <li
    class="flex items-center justify-between gap-4 border-b border-vert/10 pb-3 last:border-0 last:pb-0"
  >
    <div>
      <p class="text-sm text-ink invoice-label"></p>
      <p class="text-xs text-ink/70 invoice-meta"></p>
    </div>
    <button
      type="button"
      class="download-button shrink-0 px-4 py-2 text-xs font-semibold rounded-full border border-vert/20 text-vert hover:border-vert/40 transition-colors"
    ></button>
  </li>
</template>

<template id="message-bubble-template">
  <li class="flex message-row">
    <div class="max-w-[75%] rounded-2xl px-4 py-2 text-sm leading-relaxed message-bubble">
      <p class="message-body"></p>
      <p class="mt-1 text-[10px] opacity-70 message-time"></p>
    </div>
  </li>
</template>

<script
  is:inline
  type="application/json"
  id="account-i18n"
  set:html={JSON.stringify(t)}
/>

<script>
  import { supabase } from '../lib/supabase';

  const t = JSON.parse(
    document.getElementById('account-i18n')?.textContent ?? '{}',
  );

  // Set your own Web3Forms access key here (a dedicated one for the
  // client portal, separate from the public contact form).
  const WEB3FORMS_ACCESS_KEY = '735abfce-ffbe-4053-8df9-f00a510af473';

  const loginPath = '/connexion';

  type Message = {
    id: string;
    client_id: string;
    sender: 'client' | 'olivier';
    body: string;
    created_at: string;
  };

  let messagesChannel: ReturnType<typeof supabase.channel> | null = null;
  const renderedMessageIds = new Set<string>();

  function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('fr-FR');
  }

  function formatMessageTime(dateStr: string) {
    return new Date(dateStr).toLocaleString('fr-FR', {
      day: 'numeric',
      month: 'short',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function showSection(id: string) {
    document.getElementById(id)?.classList.remove('hidden');
  }
  function hideSection(id: string) {
    document.getElementById(id)?.classList.add('hidden');
  }

  async function renderProjects(clientId: string) {
    const list = document.getElementById('projects-list');
    const template = document.getElementById(
      'project-row-template',
    ) as HTMLTemplateElement | null;
    if (!list || !template) return;

    const { data: projects } = await supabase
      .from('projects')
      .select('id, name, status')
      .eq('client_id', clientId)
      .order('created_at', { ascending: false });

    list.innerHTML = '';
    if (!projects || projects.length === 0) {
      showSection('projects-empty');
      return;
    }
    hideSection('projects-empty');

    for (const project of projects) {
      const node = template.content.cloneNode(true) as DocumentFragment;
      const nameEl = node.querySelector('.project-name');
      const statusEl = node.querySelector('.project-status') as HTMLElement;
      if (nameEl) nameEl.textContent = project.name;
      if (statusEl) {
        const isDone = project.status === 'completed';
        statusEl.textContent = isDone ? t.statusCompleted : t.statusInProgress;
        statusEl.classList.add(
          isDone ? 'bg-vert/10' : 'bg-jaune/20',
          isDone ? 'text-vert' : 'text-amber-ink',
        );
      }
      list.appendChild(node);
    }
  }

  async function renderInvoices(clientId: string) {
    const list = document.getElementById('invoices-list');
    const template = document.getElementById(
      'invoice-row-template',
    ) as HTMLTemplateElement | null;
    if (!list || !template) return;

    const { data: invoices } = await supabase
      .from('invoices')
      .select('id, label, amount, issued_date, file_path')
      .eq('client_id', clientId)
      .order('issued_date', { ascending: false });

    list.innerHTML = '';
    if (!invoices || invoices.length === 0) {
      showSection('invoices-empty');
      return;
    }
    hideSection('invoices-empty');

    for (const invoice of invoices) {
      const node = template.content.cloneNode(true) as DocumentFragment;
      const labelEl = node.querySelector('.invoice-label');
      const metaEl = node.querySelector('.invoice-meta');
      const button = node.querySelector(
        '.download-button',
      ) as HTMLButtonElement;
      if (labelEl) labelEl.textContent = invoice.label;
      if (metaEl) {
        const amount = invoice.amount != null ? `${invoice.amount} € — ` : '';
        metaEl.textContent = `${amount}${formatDate(invoice.issued_date)}`;
      }
      if (button) {
        button.textContent = t.download;
        button.addEventListener('click', async () => {
          const { data, error } = await supabase.storage
            .from('invoices')
            .createSignedUrl(invoice.file_path, 90);
          if (error || !data) {
            button.textContent = t.downloadError;
            setTimeout(() => (button.textContent = t.download), 3000);
            return;
          }
          window.open(data.signedUrl, '_blank', 'noopener,noreferrer');
        });
      }
      list.appendChild(node);
    }
  }

  function scrollThreadToBottom() {
    const thread = document.getElementById('messages-thread');
    if (thread) thread.scrollTop = thread.scrollHeight;
  }

  function appendMessageBubble(message: Message) {
    const thread = document.getElementById('messages-thread');
    const template = document.getElementById(
      'message-bubble-template',
    ) as HTMLTemplateElement | null;
    if (!thread || !template) return;

    const node = template.content.cloneNode(true) as DocumentFragment;
    const row = node.querySelector('.message-row') as HTMLElement;
    const bubble = node.querySelector('.message-bubble') as HTMLElement;
    const isOwn = message.sender === 'client';

    row.classList.add(isOwn ? 'justify-end' : 'justify-start');
    bubble.classList.add(
      ...(isOwn
        ? ['bg-vert', 'text-white', 'rounded-br-sm']
        : ['bg-surface-alt', 'text-ink', 'rounded-bl-sm']),
    );
    const bodyEl = node.querySelector('.message-body');
    const timeEl = node.querySelector('.message-time');
    if (bodyEl) bodyEl.textContent = message.body;
    if (timeEl) timeEl.textContent = formatMessageTime(message.created_at);

    thread.appendChild(node);
    renderedMessageIds.add(message.id);
  }

  async function renderMessages(clientId: string) {
    const thread = document.getElementById('messages-thread');
    if (!thread) return;

    const { data: messages } = await supabase
      .from('messages')
      .select('id, client_id, sender, body, created_at')
      .eq('client_id', clientId)
      .order('created_at', { ascending: true });

    thread.innerHTML = '';
    renderedMessageIds.clear();

    if (!messages || messages.length === 0) {
      showSection('messages-empty');
      return;
    }
    hideSection('messages-empty');

    for (const message of messages as Message[]) {
      appendMessageBubble(message);
    }
    scrollThreadToBottom();
  }

  function subscribeToMessages(clientId: string) {
    if (messagesChannel) supabase.removeChannel(messagesChannel);
    messagesChannel = supabase
      .channel(`messages-client-${clientId}`)
      .on(
        'postgres_changes',
        {
          event: 'INSERT',
          schema: 'public',
          table: 'messages',
          filter: `client_id=eq.${clientId}`,
        },
        (payload) => {
          const message = payload.new as Message;
          if (renderedMessageIds.has(message.id)) return;
          hideSection('messages-empty');
          appendMessageBubble(message);
          scrollThreadToBottom();
        },
      )
      .subscribe();
  }

  function initMessageForm(clientId: string, clientName: string, clientEmail: string) {
    const form = document.getElementById(
      'message-form',
    ) as HTMLFormElement | null;
    const status = document.getElementById('message-status');
    const submitButton = form?.querySelector('button[type="submit"]');
    const submitLabel = submitButton?.querySelector('.submit-label');
    const textarea = document.getElementById(
      'message-body',
    ) as HTMLTextAreaElement | null;
    if (!form || !status || !submitButton || !submitLabel || !textarea) return;
    if (form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const body = textarea.value.trim();
      if (!body) return;

      submitButton.setAttribute('disabled', 'true');
      submitLabel.textContent = t.sendingMessage;
      status.classList.add('hidden');

      const { data, error } = await supabase
        .from('messages')
        .insert({ client_id: clientId, sender: 'client', body })
        .select('id, client_id, sender, body, created_at')
        .single();

      if (error || !data) {
        status.textContent = t.messageError;
        status.className = 'text-sm text-danger';
        status.classList.remove('hidden');
      } else {
        hideSection('messages-empty');
        appendMessageBubble(data as Message);
        scrollThreadToBottom();
        form.reset();

        // Notification email best-effort : la persistance en base est ce
        // qui compte, l'email n'est qu'un rappel pour Olivier.
        fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({
            access_key: WEB3FORMS_ACCESS_KEY,
            subject: `Espace client — message de ${clientName}`,
            name: clientName,
            email: clientEmail,
            replyto: clientEmail,
            message: body,
          }),
        }).catch(() => {});
      }

      submitButton.removeAttribute('disabled');
      submitLabel.textContent = t.send;
    });
  }

  function initLogout() {
    const button = document.getElementById('logout-button');
    if (!button || button.dataset.initialized) return;
    button.dataset.initialized = 'true';
    button.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = loginPath;
    });
  }

  function initGuestBackToLogin() {
    const button = document.getElementById('guest-back-to-login');
    if (!button || button.dataset.initialized) return;
    button.dataset.initialized = 'true';
    button.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = loginPath;
    });
  }

  async function init() {
    hideSection('account-content');
    hideSection('account-guest');
    showSection('account-checking');

    const {
      data: { session },
    } = await supabase.auth.getSession();

    const guestMessage = document.getElementById('account-guest-message');
    initGuestBackToLogin();

    if (!session) {
      if (guestMessage) guestMessage.textContent = t.notLoggedIn;
      hideSection('account-checking');
      showSection('account-guest');
      return;
    }

    const { data: client } = await supabase
      .from('clients')
      .select('id, name, email')
      .maybeSingle();

    if (!client) {
      if (guestMessage) guestMessage.textContent = t.noProfile;
      hideSection('account-checking');
      showSection('account-guest');
      return;
    }

    const nameEl = document.getElementById('client-name');
    if (nameEl) nameEl.textContent = client.name;

    await Promise.all([
      renderProjects(client.id),
      renderInvoices(client.id),
      renderMessages(client.id),
    ]);
    subscribeToMessages(client.id);
    initMessageForm(client.id, client.name, client.email);
    initLogout();

    hideSection('account-checking');
    showSection('account-content');
  }

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => {
    if (messagesChannel) {
      supabase.removeChannel(messagesChannel);
      messagesChannel = null;
    }
  });
</script>
