---
import Layout from '../layouts/Layout.astro';
import { routes, type Locale } from '../i18n/routes';
import { ui } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'fr') as Locale;

const copy = {
  fr: {
    title: 'Page introuvable',
    description: "Cette page n'existe pas ou a été déplacée.",
    eyebrow: 'Erreur 404',
    heading: 'Page introuvable',
    body: "Cette page n'existe pas ou a été déplacée.",
    cta: "Retour à l'accueil",
  },
  en: {
    title: 'Page not found',
    description: 'This page does not exist or has been moved.',
    eyebrow: '404 error',
    heading: 'Page not found',
    body: 'This page does not exist or has been moved.',
    cta: 'Back to home',
  },
};
const t = copy[locale];
---

<Layout title={t.title} description={t.description} noindex>
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-3xl">
      <div
        class="border border-vert/20 rounded-2xl overflow-hidden bg-white shadow-sm"
      >
        <div
          class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-[#F8F8F6]"
        >
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-[#2d2a24]/70 font-medium"
            >olivier@otvt:~/404</span
          >
        </div>
        <div class="px-6 sm:px-12 py-8 sm:py-14 text-center">
          <p
            class="text-xs text-vert/85 font-mono mb-8 sm:mb-10 leading-relaxed text-left"
          >
            <span class="text-vert font-semibold">olivier@otvt</span>:<span
              class="text-jaune">~</span
            ><span class="text-[#2d2a24]/70">$ </span><span
              class="text-[#2d2a24]/70">cat page.txt</span
            >
          </p>
          <p
            id="notfound-eyebrow"
            class="text-xs font-medium tracking-[0.15em] text-vert/85 uppercase mb-6"
          >
            {t.eyebrow}
          </p>
          <h1
            id="notfound-heading"
            class="text-5xl sm:text-6xl font-black text-[#2d2a24]"
          >
            {t.heading}
          </h1>
          <p id="notfound-body" class="mt-4 text-sm text-[#2d2a24]/70 leading-relaxed">
            {t.body}
          </p>
          <a
            id="notfound-cta"
            href={routes[locale].home}
            class="mt-8 inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm"
          >
            <span id="notfound-cta-label">{t.cta}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script
  is:inline
  define:vars={{
    routesFr: routes.fr,
    routesEn: routes.en,
    uiFr: ui.fr,
    uiEn: ui.en,
    enCopy: copy.en,
  }}
>
  if (location.pathname.startsWith('/en')) {
    document.documentElement.lang = 'en';
    document.title = document.title.replace(
      'Page introuvable',
      'Page not found',
    );

    // 404 content
    const eyebrow = document.getElementById('notfound-eyebrow');
    const heading = document.getElementById('notfound-heading');
    const body = document.getElementById('notfound-body');
    const ctaLabel = document.getElementById('notfound-cta-label');
    const cta = document.getElementById('notfound-cta');
    if (eyebrow) eyebrow.textContent = enCopy.eyebrow;
    if (heading) heading.textContent = enCopy.heading;
    if (body) body.textContent = enCopy.body;
    if (ctaLabel) ctaLabel.textContent = enCopy.cta;
    if (cta) cta.setAttribute('href', routesEn.home);

    // Header / footer nav links
    const navPairs = [
      [routesFr.home, routesEn.home, uiFr.nav.home, uiEn.nav.home],
      [routesFr.work, routesEn.work, uiFr.nav.work, uiEn.nav.work],
      [routesFr.services, routesEn.services, uiFr.nav.services, uiEn.nav.services],
      [routesFr.about, routesEn.about, uiFr.nav.about, uiEn.nav.about],
      [routesFr.contact, routesEn.contact, uiFr.nav.contact, uiEn.nav.contact],
      [routesFr.legal, routesEn.legal, uiFr.footer.legal, uiEn.footer.legal],
    ];
    for (const [oldHref, newHref, oldLabel, newLabel] of navPairs) {
      document.querySelectorAll(`a[href="${oldHref}"]`).forEach((el) => {
        el.setAttribute('href', newHref);
        if (el.textContent?.trim() === oldLabel) el.textContent = newLabel;
      });
    }

    // Footer location text
    document.querySelectorAll('footer li').forEach((el) => {
      if (el.textContent?.trim() === uiFr.footer.location) {
        el.textContent = uiEn.footer.location;
      }
    });

    // Language switcher: now showing English, so it should offer French
    document
      .querySelectorAll(`a[aria-label="${uiFr.langSwitchLabel}"]`)
      .forEach((el) => {
        el.setAttribute('href', routesFr.home);
        el.setAttribute('aria-label', uiEn.langSwitchLabel);
        el.textContent = uiEn.langSwitch;
      });

    // Mobile menu toggle button
    const menuToggle = document.getElementById('menu-toggle');
    if (menuToggle) {
      menuToggle.setAttribute('data-label-open', uiEn.menuOpen);
      menuToggle.setAttribute('data-label-close', uiEn.menuClose);
      menuToggle.setAttribute('aria-label', uiEn.menuOpen);
    }
  }
</script>
