---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page introuvable">
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-3xl">
      <div
        class="border border-vert/20 rounded-2xl overflow-hidden bg-white shadow-sm"
      >
        <div
          class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-[#F8F8F6]"
        >
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-[#2d2a24]/30 font-medium"
            >olivier@otvt:~/404</span
          >
        </div>
        <div class="px-6 sm:px-12 py-8 sm:py-14 text-center">
          <p
            class="text-xs text-vert/70 font-mono mb-8 sm:mb-10 leading-relaxed text-left"
          >
            <span class="text-vert font-semibold">olivier@otvt</span>:<span
              class="text-jaune">~</span
            ><span class="text-[#2d2a24]/25">$ </span><span
              class="text-[#2d2a24]/40">cat page.txt</span
            >
          </p>
          <p
            class="text-xs font-medium tracking-[0.15em] text-vert/80 uppercase mb-6"
          >
            Erreur 404
          </p>
          <h1 class="text-5xl sm:text-6xl font-black text-[#2d2a24]">
            Page introuvable
          </h1>
          <p class="mt-4 text-sm text-[#2d2a24]/50 leading-relaxed">
            Cette page n'existe pas ou a été déplacée.
          </p>
          <a
            href="/"
            class="mt-8 inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm"
          >
            Retour à l'accueil
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
