---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../i18n/ui';

const t = ui.en.account;
---

<Layout title="Log in" description={t.loginLede} pageKey="login" noindex>
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-xl">
      <div
        class="border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
      >
        <!-- Terminal title bar -->
        <div
          class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-surface-alt"
        >
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-ink/70 font-medium"
            >olivier@otvt:~/login</span
          >
        </div>
        <!-- Content -->
        <div class="px-6 sm:px-12 py-8 sm:py-14">
          <p
            class="text-xs text-vert/85 font-mono mb-8 sm:mb-10 leading-relaxed"
          >
            <span class="text-vert font-semibold">olivier@otvt</span>:<span
              class="text-jaune">~</span
            ><span class="text-ink/70">$ </span><span
              class="text-ink/70">./login.sh</span
            >
          </p>
          <p
            class="text-xs font-medium tracking-[0.15em] text-vert/85 uppercase"
          >
            {t.loginEyebrow}
          </p>
          <h1 class="mt-4 text-4xl sm:text-5xl font-bold text-ink">
            {t.loginTitle}
          </h1>
          <p
            id="login-lede"
            class="mt-4 text-sm text-ink/70 leading-relaxed"
          >
            {t.loginLede}
          </p>

          <!-- Step 1: email -->
          <form id="login-form" class="mt-8 space-y-5">
            <div>
              <label
                for="email"
                class="block text-xs font-medium text-ink/70 mb-1"
                >{t.emailLabel}</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-bg border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-ink placeholder-[#2d2a24]/30 transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                placeholder={t.emailPlaceholder}
              />
            </div>
            <button
              type="submit"
              class="inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span class="submit-label">{t.sendLink}</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
              >
            </button>
          </form>

          <!-- Step 2: code -->
          <form id="code-form" class="hidden mt-8 space-y-5">
            <div>
              <label
                for="code"
                class="block text-xs font-medium text-ink/70 mb-1"
                >{t.codeLabel}</label
              >
              <input
                type="text"
                inputmode="numeric"
                autocomplete="one-time-code"
                id="code"
                name="code"
                required
                class="w-full bg-bg border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-ink tracking-[0.3em] placeholder-[#2d2a24]/30 transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                placeholder={t.codePlaceholder}
              />
              <p class="mt-2 text-xs text-ink/70">{t.checkSpam}</p>
            </div>
            <div class="flex items-center gap-4">
              <button
                type="submit"
                class="inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <span class="verify-label">{t.verifyCode}</span>
              </button>
              <button
                type="button"
                id="change-email"
                class="text-sm text-ink/70 hover:text-ink transition-colors"
              >
                {t.changeEmail}
              </button>
            </div>
          </form>

          <p
            id="login-status"
            class="mt-5 text-sm hidden"
            role="status"
            aria-live="polite"
          >
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script
  type="application/json"
  is:inline
  id="login-i18n"
  set:html={JSON.stringify(t)}
/>

<script>
  import { redirectIfLoggedIn, initLoginFlow } from '../../lib/login-flow';

  const t = JSON.parse(
    document.getElementById('login-i18n')?.textContent ?? '{}',
  );

  document.addEventListener('astro:page-load', () => {
    redirectIfLoggedIn('/en/account');
    initLoginFlow('/en/account', t);
  });
</script>
