---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import meImage from '../../assets/me.png';
---

<Layout
  title="About"
  description="Olivier Thévet, independent web developer based in France, working with clients worldwide. Over 10 years of IT experience, specialized in WordPress, Next.js and Astro."
  pageKey="about"
>
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-7xl">
      <div
        class="border border-vert/20 rounded-2xl overflow-hidden bg-white shadow-sm"
      >
        <div
          class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-[#F8F8F6]"
        >
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-[#2d2a24]/70 font-medium"
            >olivier@otvt:~/about</span
          >
        </div>
        <div class="px-6 sm:px-12 py-8 sm:py-14">
          <p
            class="text-xs text-vert/85 font-mono mb-8 sm:mb-10 leading-relaxed"
          >
            <span class="text-vert font-semibold">olivier@otvt</span>:<span
              class="text-jaune">~</span
            ><span class="text-[#2d2a24]/70">$ </span><span
              class="text-[#2d2a24]/70">cat about.md</span
            >
          </p>
          <div class="grid sm:grid-cols-2 gap-12 sm:gap-16 items-center">
            <div>
              <p
                class="text-xs font-medium tracking-[0.15em] text-vert/85 uppercase mb-6"
              >
                About
              </p>
              <h1 class="text-4xl sm:text-5xl font-bold text-[#2d2a24]">
                Web developer, driven by curiosity
              </h1>
              <div
                class="mt-6 space-y-4 text-sm text-[#2d2a24]/70 leading-relaxed"
              >
                <p>
                  I'm <strong class="text-[#2d2a24]">Olivier</strong>,
                  passionate about IT and new technologies. After more than
                  10 years as an IT technician, while keeping a close eye on
                  development, I decided to go independent.
                </p>
                <p>
                  What drives me? <strong class="text-[#2d2a24]"
                    >Bringing your ideas to life</strong
                  >. Every project is a new story to write.
                </p>
                <p>
                  Working solo means no middleman: you talk directly to the
                  developer. No sales rep, no project manager, no surprises.
                </p>
              </div>
            </div>
            <div class="flex justify-center sm:justify-end">
              <div class="relative">
                <div
                  class="absolute -inset-6 bg-jaune/20 rounded-full blur-3xl"
                >
                </div>
                <div class="relative w-64 h-64 sm:w-72 sm:h-72">
                  <Image
                    src={meImage}
                    alt="Olivier Thévet"
                    width={288}
                    height={288}
                    fit="cover"
                    position="top"
                    class="w-full h-full rounded-full object-cover object-top shadow-xl"
                    loading="eager"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
