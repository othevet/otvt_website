---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Get in touch with Olivier Thévet to discuss your web project. Free quote within 48h."
  pageKey="contact"
>
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-7xl">
      <div
        class="border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
        data-reveal
      >
        <!-- Terminal title bar -->
        <div
          class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-surface-alt"
        >
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-ink/70 font-medium"
            >olivier@otvt:~/contact</span
          >
        </div>
        <!-- Content -->
        <div class="px-6 sm:px-12 py-8 sm:py-14">
          <p
            class="text-xs text-vert/85 font-mono mb-8 sm:mb-10 leading-relaxed"
          >
            <span class="text-vert font-semibold">olivier@otvt</span>:<span
              class="text-jaune">~</span
            ><span class="text-ink/70">$ </span><span
              class="text-ink/70" data-typewriter>cat contact.txt</span
            >
          </p>
          <div class="grid sm:grid-cols-2 gap-12 sm:gap-16">
            <div>
              <p
                class="text-xs font-medium tracking-[0.15em] text-vert/85 uppercase"
              >
                Contact
              </p>
              <h1 class="mt-4 text-4xl sm:text-5xl font-bold text-ink">
                Let's talk about your project
              </h1>
              <p class="mt-4 text-sm text-ink/70 leading-relaxed">
                Free quote within 48h. Fill in the form and I'll get back to
                you quickly.
              </p>
              <div class="mt-8 text-sm text-ink/70 space-y-2">
                <p class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-vert"></span>
                  <a
                    href="mailto:contact@otvt.fr"
                    class="hover:text-vert transition-colors">contact@otvt.fr</a
                  >
                </p>
                <p class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-jaune"></span>
                  <a
                    href="tel:+33635229246"
                    class="hover:text-vert transition-colors"
                    >+33 6 35 22 92 46</a
                  >
                </p>
                <p class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-vert"></span>
                  Origny le Sec, France
                </p>
              </div>
            </div>
            <div>
              <form
                id="contact-form"
                class="space-y-5"
                method="POST"
                action="https://api.web3forms.com/submit"
              >
                <input
                  type="hidden"
                  name="access_key"
                  value="c518bda7-f811-45b5-842e-7e92f268d92a"
                />
                <input
                  type="hidden"
                  name="subject"
                  value="New message from otvt.fr"
                />
                <input
                  type="checkbox"
                  name="botcheck"
                  class="hidden"
                  style="display: none;"
                  tabindex="-1"
                  autocomplete="off"
                />
                <div class="grid gap-5 sm:grid-cols-2">
                  <div>
                    <label
                      for="name"
                      class="block text-xs font-medium text-ink/70 mb-1"
                      >Name</label
                    >
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      class="w-full bg-bg border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-ink placeholder-[#2d2a24]/30 transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                      placeholder="Your name"
                    />
                  </div>
                  <div>
                    <label
                      for="email"
                      class="block text-xs font-medium text-ink/70 mb-1"
                      >Email</label
                    >
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="w-full bg-bg border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-ink placeholder-[#2d2a24]/30 transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                      placeholder="you@example.com"
                    />
                  </div>
                </div>
                <div>
                  <label
                    for="project-type"
                    class="block text-xs font-medium text-ink/70 mb-1"
                    >Project type</label
                  >
                  <select
                    id="project-type"
                    name="project-type"
                    class="w-full bg-bg border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-ink transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                  >
                    <option value="">Select...</option>
                    <option value="wordpress">WordPress</option>
                    <option value="custom">Custom website</option>
                    <option value="maintenance">Maintenance / Upgrade</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div>
                  <label
                    for="message"
                    class="block text-xs font-medium text-ink/70 mb-1"
                    >Message</label
                  >
                  <textarea
                    id="message"
                    name="message"
                    rows={5}
                    required
                    class="w-full bg-bg border border-vert/15 rounded-xl px-4 py-2.5 text-sm text-ink placeholder-[#2d2a24]/30 transition-all duration-200 focus:outline-none focus:border-vert focus:ring-2 focus:ring-vert/20"
                    placeholder="Tell me about your project..."></textarea>
                </div>
                <button
                  type="submit"
                  class="inline-flex items-center gap-2 px-6 py-3 bg-vert text-white text-sm font-medium rounded-full hover:bg-vert/90 transition-all duration-200 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  <span class="submit-label">Send</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                  >
                </button>
                <p
                  id="form-status"
                  class="text-sm hidden"
                  role="status"
                  aria-live="polite"
                >
                </p>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  function initContactForm() {
    const form = document.getElementById(
      'contact-form',
    ) as HTMLFormElement | null;
    const status = document.getElementById('form-status');
    const submitButton = form?.querySelector('button[type="submit"]');
    const submitLabel = submitButton?.querySelector('.submit-label');
    if (!form || !status || !submitButton || !submitLabel) return;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      submitButton.setAttribute('disabled', 'true');
      submitLabel.textContent = 'Sending...';
      status.classList.add('hidden');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        const result = await response.json();

        if (response.ok && result.success) {
          status.textContent = "Message sent! I'll reply within 48h.";
          status.className = 'text-sm text-vert';
          form.reset();
        } else {
          throw new Error(result.message || 'Something went wrong.');
        }
      } catch {
        status.textContent =
          'Something went wrong. Please try again or email me directly at contact@otvt.fr.';
        status.className = 'text-sm text-danger';
      } finally {
        submitButton.removeAttribute('disabled');
        submitLabel.textContent = 'Send';
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
