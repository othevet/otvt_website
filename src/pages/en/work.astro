---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Work"
  description="A look at the web projects built by Olivier Thévet: custom applications and sites developed with Next.js, Astro and Tailwind."
  pageKey="work"
>
  <section class="pt-28 pb-20 sm:pb-28 px-6">
    <div class="mx-auto max-w-7xl">
      <div
        class="border border-vert/20 rounded-2xl overflow-hidden bg-surface shadow-sm"
        data-reveal
      >
        <!-- Terminal title bar -->
        <div
          class="flex items-center gap-2 px-4 sm:px-5 py-3 border-b border-vert/10 bg-surface-alt"
        >
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-ink/70 font-medium"
            >olivier@otvt:~/apps</span
          >
        </div>
        <!-- Content -->
        <div class="px-6 sm:px-12 py-8 sm:py-14">
          <p
            class="text-xs text-vert/85 font-mono mb-8 sm:mb-10 leading-relaxed"
          >
            <span class="text-vert font-semibold">olivier@otvt</span>:<span
              class="text-jaune">~</span
            ><span class="text-ink/70">$ </span><span
              class="text-ink/70" data-typewriter>ls -la projects/</span
            >
          </p>

          <p
            class="text-xs font-medium tracking-[0.15em] text-vert/85 uppercase mb-6"
          >
            Work
          </p>
          <h1 class="text-4xl sm:text-5xl font-bold text-ink">
            What I've built
          </h1>
          <p class="mt-4 text-sm text-ink/70 leading-relaxed max-w-lg">
            Web projects ranging from WordPress to custom applications. Every
            line of code tells a story.
          </p>

          <div class="mt-12 grid gap-6 max-w-md">
            <a
              href="https://disneyday-website.vercel.app/"
              target="_blank"
              rel="noopener noreferrer"
              class="border border-vert/10 rounded-xl p-6 hover:border-vert/30 hover:-translate-y-1 hover:shadow-md transition-all duration-200 block group"
            >
              <div class="flex items-center gap-2 mb-4">
                <span class="w-2 h-2 rounded-full bg-vert"></span>
                <span class="text-xs text-vert/85 font-mono">application</span>
              </div>
              <h2
                class="text-lg font-semibold text-ink group-hover:text-vert transition-colors"
              >
                DisneyDay
              </h2>
              <p class="mt-2 text-sm text-ink/70 leading-relaxed">
                An interactive calendar of Disney history. Every day,
                discover releases, anniversaries and milestones — with an
                agenda, catalog and blog.
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span
                  class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full"
                  >Tailored</span
                >
                <span
                  class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full"
                  >Fast</span
                >
                <span
                  class="text-xs text-vert bg-vert/10 px-3 py-1 rounded-full"
                  >Responsive</span
                >
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
